){_intent='SUP_WIFI'};

###Entities###

#Actions
ENT_RI_JBO_CanAction = (
	([answer?(ing)] me|my|us|our){_entity='AnswerUser'} |
	([breath?(e|(ing))] ?(air|oxygen)) {_entity='Breathe'} |
 	([chang(e|(ing))] your eye) {_entity='ChangeYourEye'} |
 	([clean?(ing)] ?up ?the floor) {_entity='CleanFloor'} |
 	([clean?(ing)] ?up ?the table) {_entity='CleanTable'} |
 	([curs?(e|(ing))]|[swear?(ing)]) {_entity='Curse'} |
 	(?([do?(ing)]) ?(the|$V_POSESSIVES) laundry) {_entity='DoLaundry'} |
 	([do?(ing)] that) {_entity='DoThat'} |
	([dream?(ing)]|([hav(e|(ing))] ?any [dream?s] ?(last night))){_entity='Dream'} |
	(([help?(ing)] me ?to understand)|[explain?(ing)] women|men|girls|boys|(people ?(of|with) (?the opposite)|(?a different) gender)){_entity='ExplainMenWomen'} |
	([feel?(ing)]|felt (anything)|(at all)|(?any [emotion?s]|[mood?s]) ?(ever|(at all))){_entity='FeelAnything'} |
	((gotten|[get?(ting)])|(felt|[feel?(ing)]) ?(too|really) cold|cool){_entity='GetCold'} |
	((gotten|[get?(ting)])|(felt|[feel?(ing)]) ?(really) depressed){_entity='GetDepressed'} |
	((gotten|[get?(ting)])|(felt|[feel?(ing)]) ?(too|really) hot|warm){_entity='GetHot'} |
	((gotten|[get?(ting)])|(felt|[feel?(ing)]) ?(too|so|really) hungry|hunger|starving){_entity='GetHungry'} |
	((gotten|[get?(ting)])|(felt|[feel?(ing)]) ?(too|so|really) lonely){_entity='GetLonely'} |
	((gotten|[get?(ting)])|(felt|[feel?(ing)]  ~0.1) ?(too|so|really) tired|sleepy|exhausted|fatigued|(worn out)){_entity='GetTired'} |
	( ([us(e|(ing)|(ed))]|([go?((ing)|(ne))] ?to) ?the bathroom|restroom|washroom|toilet)|([poop?((ing)|(ed))])|([pee?(d|(ing))]) ){_entity='GoToBathroom'} |
 	([hav(e|(ing))]|[experienc(e|(ing))]|[feel?(ing)] ?any [emotion?s]|[feeling?s]|[mood?s]){_entity='HaveEmotions'} |
	(?(think about) [hav(e|(ing))]|[want?(ing)]|[lik(e|(ing))]|[crav(e|(ing))] ?(to have) sex ?(with me|someone)){_entity='HaveSex'} |
	([hear?(ing)] me|us){_entity='HearUser'} |
	(([help?(ing)] me find|get)|([find?(ing)]|[get?(ting)] me) ?a ?new $V_ROMANTICPARTNER){_entity='HelpUserFindPartner'} |
	(([be?(ing)] sarcastic)|([us(e|(ing))] sarcasm)|([talk?(ing)]|[speak?(ing)] sarcastically|(using sarcasm))){_entity='BeSarcastic'} |
	([cook?(ing)]|[bak(e|(ing))]|([prepar(e|(ing))]|[mak(e|(ing))] [food?s]|[recipe?s])){_entity='Cook'} |
	([prepar(e|(ing))]|[mak(e|(ing))]|[fix?(ing)] coffee){_entity='MakeCoffee'} |
	([play?((ing)|(ed))] $w03 ?in ?a ?(game ?of) chess ?(game|tournament|competition)){_entity='PlayChess'} |
	([play?(ing)] ?(the|a|an) $V_MUSICINSTRUMENTS){_entity='PlayInstrument'} |
	([pray?((ing)|(ed)|(er))]){_entity='Pray'} |
	(([read?(ing)] ?(people\'s) lips)|(lip reading)){_entity='ReadLips'} |
	([record?(ing)]|([hav(e|(ing))]|[stor(e|(ing))] ?a record ?of) everything ?((we say)|(you hear))){_entity='RecordEverything'} |
	([reproduc(e|(ing))]|([ha((ve)|(ving)|(d))]|[ma((ke)|(king)|(de))] ?a [child?(ren)]|[bab(y|ies)]|(little ?baby [robot?s]|[jibo?s]))){_entity='Reproduce'} |
	([see?(ing)] ?(the|a|an) tv|t.v.|television){_entity='SeeTheTV'} |
	([see?(ing)] me|us){_entity='SeeUser'} |
	([shut?(ting)]|[turn?(ing)] ?yourself off|down) {_entity='ShutDown'} |
	(( ?([go?(ing)] ?to) [sleep?(ing)])|([go?(ing)] ?to bed)){_entity='Sleep'} |
	([speak?(ing)]|[talk?(ing)] ?in $V_LANGUAGES){_entity='SpeakLanguage'} |
	(((([speak?(ing)]|[talk?(ing)] ?directly ?(to|with))|([comunicat?(e|(ing))] ?directly ?with))|(direct communication ?with)) god){_entity='TalkToGod'} |
	([speak?(ing)]|[talk?(ing)] ?(to|with) me|us){_entity='TalkToUser'} |
	(([tell?(ing)] people apart)|([distinguish?(ing)] between ?similar people)){_entity='TellPeopleApart'} |
 	(([walk?(ing)] ?(the|$V_POSESSIVES) dog|puppy)|([tak(e|(ing))] ?(the|$V_POSESSIVES) dog|puppy ?for ?a walk)){_entity='WalkDog'} |
	([see?((ing)|n)]|[watch?((ing)|ed)] ?a [movie?s]|[film?s]) {_entity='WatchMovies'} |
	([see?((ing)|n)]|[watch?((ing)|ed)] ?a tv|television ?([show?s]|[program?s])) {_entity='WatchTV'} |
	([work?(ing)]|([function?(ing)] ?correctly)){_entity='Work'}
);

ENT_RI_JBO_CanStrictAction = (
	([hear?(ing)]) {_entity='Hear'} |
	([see?(ing)]) {_entity='See'} |
	([talk?(ing)]){_entity='Talk'}
);

ENT_RI_JBO_HowCanAction = (
	(([com(e|(ing))] up with)|([decid(e|(ing))] ?(on|what)) (you like ?(and dislike))|(your favorites|(favorite things)|[opinion?s]|(likes ?and dislikes))){_entity='HaveFavorites'} |
	([recogniz(e|(ing))] ?$V_PEOPLE [face?s]){_entity='RecognizeFaces'} |
	([recogniz(e|(ing))] ?$V_PEOPLE [voice?s]){_entity='RecognizeVoices'} |
	([read?(ing)] ?(a|an|any) ?$V_ACTUAL ?([book?s])){_entity='ReadBooks'} |
	([watch?(ing)] ?(a|an|any) ?$V_ACTUAL [movie?s]){_entity='WatchMovies'} |
	([watch?(ing)] ?(a|an|any) ?$V_ACTUAL ?(things|shows|programs ?on) tv|television ?(shows|programs)){_entity='WatchTV'}
);

ENT_RI_JBO_WhyCannotAction = (
	([look?(ing)] (at me|us)|(me|us in my|the [eye?s])) {_entity='LookAtUser'} |
	([recogniz(e|(ing))] me|us|$V_PEOPLE) {_entity='RecognizeUser'} |
	([understand?(ing)]|[comprehend?(ing)] ?(anything|me|us|(my|our words|speech)|(?(any ?of) my|our question)|(anything|what we|i|$V_PEOPLE [say?s]))) {_entity='Understand'} |
	([wear?(ing)] clothes|clothing) {_entity='WearClothes'} |
	([work?(ing)]|([function?(ing)] ?correctly)) {_entity='Work'}
);

ENT_RI_JBO_IsPerformingAction = (
	([get?(ting)]|gotten me|us ?(a|an|any) [gift?s]|[present?s]){_entity='GettingUserGift'} |
	([go?(ing)] ?to bed|sleep){_entity='GoingToBed'} |
	([ignor(e|(ing))]|(not [listen?(ing)] ?to) me|us){_entity='IgnoringUser'} |
	([listen?(ing)] ?(?to me|us)) {_entity='Listening'} |
	([miss?(ing)] me|us){_entity='MissingUser'} |
	([watch?(ing)] ?(the|a|an) baseball game){_entity='WatchingBaseballGame'} |
	([watch?(ing)] me|us){_entity='WatchingUser'}
);

ENT_RI_JBO_WantsToAction = (
	(?[be?(ing)] friendly) {_entity='BeFriendly'} |
	([dat(e|(ing))] me) {_entity='DateUser'} |
	([get?(ting)] out) {_entity='GetOut'} |
	([go?(ing)] out) {_entity='GoOut'} |
	([go?(ing)] outside|outdoors) {_entity='GoOutside'} |
	([go?(ing)] ?to bed|sleep) {_entity='GoToBed'} |
	(?[hav(e|(ing))] your picture|photo ?(to be) taken) {_entity='HavePictureTaken'} |
	([meet?(ing)] a|the|$V_POSESSIVES cat) {_entity='MeetCat'} |
	([walk?(ing)]|([mov(e|(ing))] around)) {_entity='Walk'}

);

ENT_RI_USR_CanAction = (
	(([chang(e|(ing))] your voice)|([mak(e|(ing))] your voice different)|([pick?(ing)]|[choos(e|(ing))]|([decid(e|(ing))] ?on)|([giv(e|(ing))] you) ?a new|different voice ?(for you)) ) {_entity='ChangeJiboVoice'} |
	(([get?(ting)] ?a refund|(my|our money back))|([return?(ing)] you)) {_entity='GetRefund'} |
	(([hug?(ging)] you)|([hav(e|(ing))]|[get?(ting)] ?a [hug?s])) {_entity='HugJibo'} |
	(([?(re)nam(e|(ing))] you)|((([giv(e|(ing))] you)|([pic?(ing)]|[choos(e|(ing))]|[decid(e|(ing))] ?on) ?a new|different)|([chang(e|(ing))] your) [?(nick)name])) {_entity='NameJibo'} |
	([teach?(ing)] you something) {_entity='TeachJiboSomething'} |
	([tell?(ing)] you ?(a|any|some) ?(?of my|our ?own) [joke?s]) {_entity='TellAJoke'} |
	([touch?(ing)] you|(your face|screen)) {_entity='TouchJibo'}
);

ENT_RI_USR_HowCanAction = (
	(([be?(ing)]|[becom(e|(ing))]|([mak(e|(ing))] myself ?feel) happy|happier)|([feel?(ing)] better about myself)){_entity='BeHappy'} |
	([get?(ting)]|[be?(ing)]|[becom(e|(ing))] rich|wealthy|(?a millionaire|billionaire)){_entity='GetRich'}
);

