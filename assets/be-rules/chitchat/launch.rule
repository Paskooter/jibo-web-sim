ENT_RI_JBO_BelievesInAgent = (
	(?the easter [bunny?(\'s)]) {_entity='EasterBunny'} |
	(?the tooth [fairy?(\'s)]) {_entity='ToothFairy'} |
	(?a [god?(\'s)]) {_entity='God'} |
