){_mimId='OI_USR_TravelsTo'}{_mimId += ENT_OI_USR_TravelsToLocation._entity}
;
RULE_OI_USR_NewYearResolutions = (
	((my|our) new (year|years|year\'s) [resolution?s] (is|are) +$w) |
