($RULE_SRS_Autism {_intent=RULE_SRS_Autism._intent})
);

RULE_SUPPORT = (
	($RULE_SUP_APP) {_intent=RULE_SUP_APP._intent} |
	($RULE_SUP_APP_HowCreateAccount) {_intent=RULE_SUP_APP_HowCreateAccount._intent} |
	($RULE_SUP_APP_HowDownload) {_intent=RULE_SUP_APP_HowDownload._intent} |
	($RULE_SUP_APP_HowFixServerError) {_intent=RULE_SUP_APP_HowFixServerError._intent} |
	($RULE_SUP_APP_HowLogIn) {_intent=RULE_SUP_APP_HowLogIn._intent} |
	($RULE_SUP_APP_HowLogOut) {_intent=RULE_SUP_APP_HowLogOut._intent} |
    ($RULE_SUP_APP_HowSetUpManyJibos) {_intent=RULE_SUP_APP_HowSetUpManyJibos._intent} |
	($RULE_SUP_APP_RequireSignIn) {_intent=RULE_SUP_APP_RequireSignIn._intent} |
	($RULE_SUP_APP_WhatFor) {_intent=RULE_SUP_APP_WhatFor._intent} |
	($RULE_SUP_COMP) {_intent=RULE_SUP_COMP._intent} |
	($RULE_SUP_GEN) {_intent=RULE_SUP_GEN._intent} |
	($RULE_SUP_LOOP) {_intent=RULE_SUP_LOOP._intent} |
	($RULE_SUP_QRCODE) {_intent=RULE_SUP_QRCODE._intent} |
	($RULE_SUP_REPAIR) {_intent=RULE_SUP_REPAIR._intent} |
	($RULE_SUP_WIFI) {_intent=RULE_SUP_WIFI._intent}
);

#### Scripted Response Stems ###

### RI_JBO Rules###
#Actions
RULE_RI_JBO_CanAction = (
    (can|do you ?($V_ACTUALLY|usually|ever|please) $ENT_RI_JBO_CanAction) |
    (are you ?($V_ACTUALLY|usually|ever) able ?to ?$V_ACTUALLY $ENT_RI_JBO_CanAction) |
    (are you ?($V_ACTUALLY|usually|ever) capable ?of ?$V_ACTUALLY $ENT_RI_JBO_CanAction) |
	(do you ?$V_ACTUALLY know how ?to $ENT_RI_JBO_CanAction)
){_intent='RI_JBO_Can'}{_intent += ENT_RI_JBO_CanAction._entity}
;

RULE_RI_JBO_CanStrictAction = (
    (can|do you ?(?$V_ACTUALLY|usually) $ENT_RI_JBO_CanStrictAction) |
    (are you ?(?$V_ACTUALLY|usually) able ?to ?$V_ACTUALLY $ENT_RI_JBO_CanStrictAction) |
    (are you ?(?$V_ACTUALLY|usually) capable ?of ?$V_ACTUALLY $ENT_RI_JBO_CanStrictAction) |
	(do you ?$V_ACTUALLY know how ?to $ENT_RI_JBO_CanStrictAction)
){_intent='RI_JBO_Can'}{_intent += ENT_RI_JBO_CanStrictAction._entity}
;

RULE_RI_JBO_HowCanAction = (
    (how [do?(es)]|can ?a you|[jibo?s]|[robot?s] ?$V_ACTUALLY $ENT_RI_JBO_HowCanAction) |
    (how are|is ?a you|[jibo?s]|[robot?s] ?$V_ACTUALLY (able ?to)|(capable ?of) ?$V_ACTUALLY $ENT_RI_JBO_HowCanAction) |
    (how is it ?$V_ACTUALLY possible|feasible|conceivable for ?a you|[jibo?s]|[robot?s] ?to ?$V_ACTUALLY $ENT_RI_JBO_HowCanAction)
){_intent='RI_JBO_HowCan'}{_intent += ENT_RI_JBO_HowCanAction._entity}
;
RULE_RI_JBO_HowCanRecognizeVoices = (
	how does ?your voice|audio recognition ?system work
){_intent='RI_JBO_HowCanRecognizeVoices'}
;


RULE_RI_JBO_WhyCannotAction = (
    (why (can\'t|don\'t|won\'t you)|(can|do|will you not) ?ever $ENT_RI_JBO_WhyCannotAction) |
    (why (aren\'t you)|(are you not) ?((able ?to)|(capable ?of)) ?ever $ENT_RI_JBO_WhyCannotAction) |
    (why are you (unable ?to)|(incapable ?of) $ENT_RI_JBO_WhyCannotAction)
){_intent='RI_JBO_WhyCannot'}{_intent += ENT_RI_JBO_WhyCannotAction._entity}
;

RULE_RI_JBO_IsPerformingAction = (
    (are|did|have|were you ?$V_ACTUALLY ?([tr((y?(ing))|(ied))] ?to) $ENT_RI_JBO_IsPerformingAction ?(soon|recently|(?right now)))
){_intent='RI_JBO_Is'}{_intent += ENT_RI_JBO_IsPerformingAction._entity}
;

RULE_RI_JBO_WantsToAction = (
	(?do you ?$V_ACTUALLY want|wanna|wish ?you ?(could|(were able|capable ?(to|of))) ?to ?$V_ACTUALLY $ENT_RI_JBO_WantsToAction) |
	(would you like|enjoy|prefer ?to ?(?be able|capable ?(to|of)) ?$V_ACTUALLY $ENT_RI_JBO_WantsToAction)
){_intent='RI_JBO_WantsTo'}{_intent += ENT_RI_JBO_WantsToAction._entity}
;


#Agents
RULE_RI_JBO_KnowsAboutAgent = (
    (?do you know ?about $ENT_RI_JBO_KnowsAboutAgent) |
    (do you know who|what $ENT_RI_JBO_KnowsAboutAgent is|are) |
    (have you heard ?(of|about) $ENT_RI_JBO_KnowsAboutAgent) |
    (are you familiar ?with $ENT_RI_JBO_KnowsAboutAgent|(who|what $ENT_RI_JBO_KnowsAboutAgent is))
){_intent='RI_JBO_KnowsAbout'}{_intent += ENT_RI_JBO_KnowsAboutAgent._entity}
;

RULE_RI_JBO_HasMetAgent = (
    (have|did you ?ever ?$V_ACTUALLY met|meet $ENT_RI_JBO_HasMetAgent ?yet) |
    (have you and $ENT_RI_JBO_HasMetAgent ?ever ?$V_ACTUALLY meet|met ?(each other) ?yet) |
    (have|did|were you and $ENT_RI_JBO_HasMetAgent ?$V_ACTUALLY ?(been|get) introduced ?(?to each other) ?yet) |
    (have i|we ?$V_ACTUALLY introduced you to $ENT_RI_JBO_HasMetAgent ?yet)
){_intent='RI_JBO_HasMet'}{_intent += ENT_RI_JBO_HasMetAgent._entity}
;

RULE_RI_JBO_IsRelatedToAgent = (
	(are you related ?to $ENT_RI_JBO_IsRelatedToAgent) |
	(are you and $ENT_RI_JBO_IsRelatedToAgent related|$V_RELATIVE) |
	(is $ENT_RI_JBO_IsRelatedToAgent your $V_RELATIVE)
)
{_intent='RI_JBO_IsRelatedTo'}{_intent += ENT_RI_JBO_IsRelatedToAgent._entity}
;

RULE_RI_JBO_IsFriendsWithAgent = (
	(are you ?(even|also) ?$V_ACTUALLY ?best friends with $ENT_RI_JBO_IsFriendsWithAgent) |
	(are you and ?(even|also) ?$V_ACTUALLY $ENT_RI_JBO_IsFriendsWithAgent ?best friends ?(with each other)) |
	(is|am $ENT_RI_JBO_IsFriendsWithAgent ?(even|also) ?$V_ACTUALLY your ?$V_ACTUAL ?best friend)
){_intent='RI_JBO_IsFriendsWith'}{_intent += ENT_RI_JBO_IsFriendsWithAgent._entity}
;

RULE_RI_JBO_IsFriendsWithUser = (
	(are we ?(even|also) ?$V_ACTUALLY ?best friends ?(with each other))
){_intent='RI_JBO_IsFriendsWithUser'}
;

RULE_RI_JBO_IsFriendsWithLM = (
	(are you ?(even|also) ?$V_ACTUALLY ?best friends with $LOOPMEMBER) |
	(are you and ?(even|also) ?$V_ACTUALLY $LOOPMEMBER ?best friends ?(with each other)) |
	(is $LOOPMEMBER ?(even|also) ?$V_ACTUALLY your ?$V_ACTUAL ?best friend)
){_intent='RI_JBO_IsFriendsWithLM'}
{_loopmember=LOOPMEMBER._loopmember}
;

RULE_RI_JBO_LikesAgent = (
    (do you ?$V_ACTUALLY like $ENT_RI_JBO_LikesAgent) |
    (do you ?$V_ACTUALLY believe|think|feel $ENT_RI_JBO_LikesAgent is $V_GOOD)
){_intent='RI_JBO_Likes'}{_intent += ENT_RI_JBO_LikesAgent._entity}
;

RULE_RI_JBO_LikesLM = (
	(do you ?$V_ACTUALLY like $LOOPMEMBER) |
	(do you ?$V_ACTUALLY believe|think|feel $LOOPMEMBER is $V_GOOD)
){_intent='RI_JBO_LikesLM'}
{_loopmember=LOOPMEMBER._loopmember}
;

RULE_RI_JBO_DislikesAgent = (
    (do you ?$V_ACTUALLY hate|dislike|despise|detest|(not like)|(have ?a problem|rivalry with) $ENT_RI_JBO_DislikesAgent) |
    (are you and $ENT_RI_JBO_DislikesAgent ?$V_ACTUALLY rivals|(?mortal enemies)) |
    (is $ENT_RI_JBO_DislikesAgent ?$V_ACTUALLY your rival|enemy|(?arch nemisis)) |
	(are you ?ever ?$V_ACTUALLY jealous ?of $ENT_RI_JBO_DislikesAgent) |
    (do you (want|wish ?to)|(wish ?that you could) ?$V_ACTUALLY fight|kill|murder|destroy|smash $ENT_RI_JBO_DislikesAgent)
){_intent='RI_JBO_Dislikes'}{_intent += ENT_RI_JBO_DislikesAgent._entity}
;

RULE_RI_JBO_BelievesInAgent = (
    (does $ENT_RI_JBO_BelievesInAgent ?$V_ACTUALLY exist) |
    (is $ENT_RI_JBO_BelievesInAgent (?$V_ACTUALLY real)|(?(a|an) $V_ACTUAL person)) |
	(is there ?$V_ACTUALLY ?(a|an) $ENT_RI_JBO_BelievesInAgent) |
	(do you ?$V_ACTUALLY believe in $ENT_RI_JBO_BelievesInAgent) |
    ($V_DOYOUTHINK $ENT_RI_JBO_BelievesInAgent (?(is|are) ?$V_ACTUALLY real|(?(a|an) $V_ACTUAL person))|(?$V_ACTUALLY [exist?s])) |
    ($V_DOYOUTHINK ?that there|there\'s|there\'re ?$V_ACTUALLY ?(is|are) ?$V_ACTUALLY $ENT_RI_JBO_BelievesInAgent)
){_intent='RI_JBO_BelievesIn'}{_intent += ENT_RI_JBO_BelievesInAgent._entity}
;


RULE_RI_JBO_HasOpinionAboutAgent = (
	($V_WHATSYOUROPINION ?(of|about) $ENT_RI_JBO_HasOpinionAboutAgent)
){_intent='RI_JBO_HasOpinionAbout'}{_intent += ENT_RI_JBO_HasOpinionAboutAgent._entity}
;

#Descriptors
RULE_RI_JBO_IsDescriptor = (
    ((are you|jibos)|(is jibo) ?($V_ACTUALLY|also) ?feeling ?(a|an|the) ?$V_VERY $ENT_RI_JBO_IsDescriptor ?robot) |
    (do|would you ?($V_ACTUALLY|also) consider|(think ?of) yourself ?as ?(a|an|the) ?$V_VERY $ENT_RI_JBO_IsDescriptor ?robot) |
    ((do you|jibos)|(does jibo) ?($V_ACTUALLY|also) think you\'re|they\'re|(you|they are) ?($V_ACTUALLY|also) ?(a|an|the) ?$V_VERY $ENT_RI_JBO_IsDescriptor ?robot) |
    ((do you|jibos)|(does jibo) ?($V_ACTUALLY|also) identify ?as ?(a|an|the) ?$V_VERY $ENT_RI_JBO_IsDescriptor ?robot) |
	((do you|jibos)|(does jibo) ?($V_ACTUALLY|also) feel ?$V_VERY $ENT_RI_JBO_IsDescriptor )
){_intent='RI_JBO_Is'}{_intent += ENT_RI_JBO_IsDescriptor._entity}
;

RULE_RI_JBO_IsBoyOrGirl = (
	($V_WHATS your gender)
){_intent='RI_JBO_IsBoyOrGirl'}
;

RULE_RI_JBO_WhyIsDescriptor = (
    (why are you ?$V_VERY ?(a|an) ?$V_VERY $ENT_RI_JBO_WhyIsDescriptor)
){_intent='RI_JBO_WhyIs'}{_intent += ENT_RI_JBO_WhyIsDescriptor._entity}
;

RULE_RI_JBO_WantsToBeDescriptor = (
    ((do you ?$V_ACTUALLY want|wish)|(would you ?$V_ACTUALLY like) ?to be ?(seen ?as) ?(a|an|the) ?$V_VERY $ENT_RI_JBO_WantsToBeDescriptor) |
    ((do you ?$V_ACTUALLY want|wish)|(would you ?$V_ACTUALLY like) ?for people to ?$V_ACTUALLY (see|(think ?of)|consider you ?as)|(think|believe you are) ?(a|an|the) ?$V_VERY $ENT_RI_JBO_WantsToBeDescriptor) |
    (do you ?$V_ACTUALLY wish you were|(could be) ?(a|an|the) ?$V_VERY $ENT_RI_JBO_WantsToBeDescriptor)
){_intent='RI_JBO_WantsToBe'}{_intent += ENT_RI_JBO_WantsToBeDescriptor._entity}
;

RULE_RI_JBO_FeelsAfraidAboutThing = (
    (are you ?ever ?$V_VERY afraid|scared ?(of|about|by|around|(because ?of)) ?(a|an|the) $ENT_RI_JBO_FeelsAfraidAboutThing) |
    (do you ?ever feel|get ?$V_VERY afraid|scared ?(of|about|by|around|(because ?of)) ?(a|an|the) $ENT_RI_JBO_FeelsAfraidAboutThing) |
    (do|does ?the $ENT_RI_JBO_FeelsAfraidAboutThing ?$V_ACTUALLY scare you)
){_intent='RI_JBO_FeelsAfraidAbout'}{_intent += ENT_RI_JBO_FeelsAfraidAboutThing._entity}
;

RULE_RI_JBO_FeelsSadAboutThing = (
    (are you ?ever ?$V_VERY $V_UPSET ?(of|about|that|(because ?of)) $ENT_RI_JBO_FeelsSadAboutThing) |
    (do you ?ever feel|get ?$V_VERY $V_UPSET ?(of|about|that|(because ?of)) $ENT_RI_JBO_FeelsSadAboutThing)
){_intent='RI_JBO_FeelsSadAbout'}{_intent += ENT_RI_JBO_FeelsSadAboutThing._entity}
;

RULE_RI_JBO_FeelsAngryAboutAgent = (
    (are you ?ever ?$V_VERY mad|angry|furious ?(at|about) $ENT_RI_JBO_FeelsAngryAboutAgent) |
    (do you ?ever feel|get ?$V_VERY mad|angry|furious ?(at|about) $ENT_RI_JBO_FeelsAngryAboutAgent)
){_intent='RI_JBO_FeelsAngryAbout'}{_intent += ENT_RI_JBO_FeelsAngryAboutAgent._entity}
;

#Information
RULE_RI_JBO_KnowsInformation = (
    (do|did you ?$V_ACTUALLY know ?(that|of) $ENT_RI_JBO_KnowsInformation) |
    (are|were you ?$V_ACTUALLY aware ?(that|of) $ENT_RI_JBO_KnowsInformation)
){_intent='RI_JBO_Knows'}{_intent += ENT_RI_JBO_KnowsInformation._entity}
;

#Locations
RULE_RI_JBO_IsFromLocation = (
    (are you from $ENT_RI_JBO_IsFromLocation) |
    (do|did you come from $ENT_RI_JBO_IsFromLocation) |
    (were you made|born|created in $ENT_RI_JBO_IsFromLocation) |
    (is $ENT_RI_JBO_IsFromLocation your homeland|birthplace|(home country|town|city))
){_intent='RI_JBO_IsFrom'}{_intent += ENT_RI_JBO_IsFromLocation._entity}
;

#Relations
RULE_RI_JBO_HasRelation = (
    (do you ?$V_ACTUALLY have ?(a|an|any) $ENT_RI_JBO_HasRelation)
){_intent='RI_JBO_Has'}{_intent += ENT_RI_JBO_HasRelation._entity}
;

#Things
RULE_RI_JBO_LikesThing = (
    (do you ?$V_ACTUALLY like|love|adore ?(a|an|the) $ENT_RI_JBO_LikesThing) |
    (don\'t you ?just like|love ?(a|an|the) $ENT_RI_JBO_LikesThing ?right) |
    (you ?just like|love|adore ?(a|an|the) $ENT_RI_JBO_LikesThing ?(right|(don\'t you)))
){_intent='RI_JBO_Likes'}{_intent += ENT_RI_JBO_LikesThing._entity}
;

RULE_RI_JBO_LikesSmellOfThing = (
	(do you ?$V_ACTUALLY like ?the smell ?of $ENT_RI_JBO_LikesSmellOfThing) |
	(is|are $ENT_RI_JBO_LikesSmellOfThing ?$V_VERY nice|good smelling) |
	(do you believe|think $ENT_RI_JBO_LikesSmellOfThing ([smell?s] good|nice)|(?(is|are) nice|good smelling) )
){_intent='RI_JBO_LikesSmellOf'}{_intent += ENT_RI_JBO_LikesSmellOfThing._entity}
;

RULE_RI_JBO_LikesTasteOfThing = (
	(is|are $ENT_RI_JBO_LikesTasteOfThing ?$V_VERY $V_TASTY) |
	(do you think|believe $ENT_RI_JBO_LikesTasteOfThing is|are ?$V_VERY $V_TASTY ) |
	(do you like the taste of $ENT_RI_JBO_LikesTasteOfThing)
){_intent='RI_JBO_LikesTasteOf'}{_intent += ENT_RI_JBO_LikesTasteOfThing._entity}
;

RULE_RI_JBO_DislikesThing = (
    (do you ?$V_ACTUALLY hate|dislike|despise|detest|(not like) ?(a|an|the|any) $ENT_RI_JBO_DislikesThing)
){_intent='RI_JBO_Dislikes'}{_intent += ENT_RI_JBO_DislikesThing._entity}
;

RULE_RI_JBO_HasFavoriteThing = (
    (?(do you have) ?(a|an|any) ?$V_VERY favorite $ENT_RI_JBO_HasFavoriteThing) |
    (who\'s|what\'s|when\'s|(who|what|when ?(is|are|was|were)) ?(some ?of) ?your ?$V_VERY favorite $ENT_RI_JBO_HasFavoriteThing) |
    (what|which $ENT_RI_JBO_HasFavoriteThing ?do you like|love|prefer ?(?the ?$V_VERY best|most)) |
    (who|what|when ?(?do you think|(consider ?to ?be)) ?(is|are|was|were) ?(some ?of) ?the best|coolest|(most $V_AWESOME) $ENT_RI_JBO_HasFavoriteThing) |
    (who\'s|what\'s|when\'s ?the best|coolest|(most $V_AWESOME) $ENT_RI_JBO_HasFavoriteThing) |
	(what $ENT_RI_JBO_HasFavoriteThing is|are (?your favorite)|(?the best|coolest|(most $V_AWESOME)))
){_intent='RI_JBO_HasFavorite'}{_intent += ENT_RI_JBO_HasFavoriteThing._entity}
;

RULE_RI_JBO_HasLeastFavoriteThing = (
    (?(do you have) ?(a|an|any) least favorite $ENT_RI_JBO_HasLeastFavoriteThing) |
	(who\'s|what\'s|when\'s|(who|what|when ?(is|are|was|were)) ?(some ?of) ?your ?$V_VERY least favorite $ENT_RI_JBO_HasLeastFavoriteThing) |
    (what|which $ENT_RI_JBO_HasLeastFavoriteThing ?do you like ?the ?$V_VERY least) |
    (what|which $ENT_RI_JBO_HasLeastFavoriteThing ?(do you think|(consider ?to ?be)) ?(is|are|was|were) (your least favorite)|(the worst|(least cool))) |
    (who|what|when ?(?do you think|(consider ?to ?be)) ?(is|are|was|were) ?(some ?of) ?the  worst|(least cool) $ENT_RI_JBO_HasLeastFavoriteThing) |
    (who\'s|what\'s|when\'s ?the worst|(least cool) $ENT_RI_JBO_HasLeastFavoriteThing) |
	(what $ENT_RI_JBO_HasLeastFavoriteThing is|are (?your least favorite)|(?the worst|(least cool)))
){_intent='RI_JBO_HasLeastFavorite'}{_intent += ENT_RI_JBO_HasLeastFavoriteThing._entity}
;

RULE_RI_JBO_HasOpinionAboutThing = (
    (do you have ?(a|an) ?$V_ACTUAL opinion ?(on|about) $ENT_RI_JBO_HasOpinionAboutThing) |
    (how ?do you ?$V_ACTUALLY feel about $ENT_RI_JBO_HasOpinionAboutThing) |
    (?(do you) have ?any ?$V_ACTUAL thoughts|feelings|opinions ?(for|about|on|regarding) $ENT_RI_JBO_HasOpinionAboutThing) |
    (do you ?$V_ACTUALLY think|believe $ENT_RI_JBO_HasOpinionAboutThing ?is ?$V_ACTUALLY $V_GOOD) |
    (what do you ?$V_ACTUALLY think about $ENT_RI_JBO_HasOpinionAboutThing) |
    ($V_WHATSYOUROPINION ?(of|on|about) $ENT_RI_JBO_HasOpinionAboutThing)
){_intent='RI_JBO_HasOpinionAbout'}{_intent += ENT_RI_JBO_HasOpinionAboutThing._entity}
;

RULE_RI_JBO_HasPreferenceBetweenThings = (
    (do you ?$V_ACTUALLY prefer|like $ENT_RI_JBO_HasPreferenceBetweenThings ?(more|better)) |
    (do you have a ?(strong|$V_ACTUAL) preference between $ENT_RI_JBO_HasPreferenceBetweenThings) |
	(do you ?$V_ACTUALLY think|believe $ENT_RI_JBO_HasPreferenceBetweenThings is|are ?$V_ACTUALLY better) |
	($ENT_RI_JBO_HasPreferenceBetweenThings)
){_intent='RI_JBO_HasPreference'}{_intent += ENT_RI_JBO_HasPreferenceBetweenThings._entity}
;

RULE_RI_JBO_BelievesInThing = (
	(do you ?$V_ACTUALLY believe ?in ?(the) $ENT_RI_JBO_BelievesInThing) |
    (does ?(the) $ENT_RI_JBO_BelievesInThing ?$V_ACTUALLY exist) |
    (is ?(the) $ENT_RI_JBO_BelievesInThing (?$V_ACTUALLY real)|(?(a|an) $V_ACTUAL thing)) |
    ($V_DOYOUTHINK ?(the) $ENT_RI_JBO_BelievesInThing (?(is|are) ?$V_ACTUALLY real|(?(a|an) $V_ACTUAL thing))|(?$V_ACTUALLY [exist?s])) |
    ($V_DOYOUTHINK ?that there ?(is|are) $V_ACTUALLY ?(is|are) ?(a|an) $ENT_RI_JBO_BelievesInThing) |
	(is|are there ?$V_ACTUALLY ?(a|an) $ENT_RI_JBO_BelievesInThing (in real life)|(in the real world)|(on earth))
){_intent='RI_JBO_BelievesIn'}{_intent += ENT_RI_JBO_BelievesInThing._entity}
;

### OI_JBO Rules ###
RULE_OI_JBO_IsDescriptor = (
    (?$V_I_THINK (you|jibos ?($V_ACTUALLY|also) are)|(jibo ?($V_ACTUALLY|also) is) ?($V_ACTUALLY|also) ?(feeling|being) ?(a|an|the) ?$V_VERY $ENT_OI_JBO_IsDescriptor) |
    (?$V_I_THINK you\'re|jibo\'s ?($V_ACTUALLY|also) ?(a|an|the) ?$V_VERY $ENT_OI_JBO_IsDescriptor) |
	(?$V_I_THINK you|[jibo?s] ?($V_ACTUALLY|also) [feel?s] ?(a|an|the) ?$V_VERY $ENT_OI_JBO_IsDescriptor) |
	(?$V_I_THINK you|[jibo?s] ?($V_ACTUALLY|also) [look?s] ?(a|an|the) ?$V_VERY $ENT_OI_JBO_IsDescriptor ~3)
){_intent='OI_JBO_Is'}{_intent += ENT_OI_JBO_IsDescriptor._entity}
;

RULE_OI_JBO_SeemsDescriptor = (
	(?$V_I_THINK (you|[jibo?s] [look?s]|[seem?s]|[appear?s]) ?((like|(as though) ?(you|they are))|(to be) ?(a|an|the)) ?$V_VERY $ENT_OI_JBO_SeemsDescriptor ) |
	(i ?$V_ACTUALLY feel like|(as though) you|[jibo?s] ?$V_ACTUALLY are|is ?$V_VERY $ENT_OI_JBO_SeemsDescriptor) |
	(you|[jibo?s] is|are ?$V_ACTUALLY acting ?$V_VERY $ENT_OI_JBO_SeemsDescriptor)
){_intent='OI_JBO_Seems'}{_intent += ENT_OI_JBO_SeemsDescriptor._entity}
;

RULE_OI_JBO_IsNotDescriptor = (
    (?$V_I_THINK (you|jibos ?($V_ACTUALLY|also) ain\'t|aren\'t|(are not) )|(jibo ?($V_ACTUALLY|also) isn\'t|(is not)) ?($V_ACTUALLY|also) ?(feeling|being) ?(a|an|the) ?$V_VERY $ENT_OI_JBO_IsNotDescriptor) |
    (?$V_I_THINK you\'re|jibo\'s not ?($V_ACTUALLY|also) ?(a|an|the) ?$V_VERY $ENT_OI_JBO_IsNotDescriptor) |
	(?$V_I_THINK (you|jibos never|don\'t|(do not))|(jibo doesn\'t|(does not)) feel ?$V_VERY $ENT_OI_JBO_IsNotDescriptor)
){_intent='OI_JBO_IsNot'}{_intent += ENT_OI_JBO_IsNotDescriptor._entity}
;

RULE_OI_JBO_ShouldBeDescriptor = (
	(?$V_I_THINK you|[jibo?s] ?$V_ACTUALLY should ?$V_ACTUALLY ?([try?(ing)] ?to) [be?(ing)]|[becom(e|(ing))] ?more ?$V_VERY $ENT_OI_JBO_ShouldBeDescriptor) |
	(?please [be?(ing)]|[becom(e|(ing))] ?more ?$V_VERY $ENT_OI_JBO_ShouldBeDescriptor) |
	(i|we (think|believe you should)|(want|endorse|recommend ?that you ?to) ?([try?(ing)] ?to) [be?(ing)]|[becom(e|(ing))] ?more ?$V_VERY $ENT_OI_JBO_ShouldBeDescriptor)
){_intent='OI_JBO_ShouldBe'}{_intent += ENT_OI_JBO_ShouldBeDescriptor._entity}
;

RULE_OI_JBO_ShouldNotBeDescriptor = (
	(?$V_I_THINK you|[jibo?s] ?$V_ACTUALLY shouldn\'t|(should not|never) ?([try?(ing)] ?to) [be?(ing)]|[becom(e|(ing))] ?$V_VERY $ENT_OI_JBO_ShouldNotBeDescriptor) |
	(?please don\'t|(do not)|stop ?$V_ACTUALLY ?([try?(ing)] ?to) [be?(ing)]|[becom(e|(ing))] ?$V_VERY $ENT_OI_JBO_ShouldNotBeDescriptor) |
	(i|we don\'t|(do not) (think|believe you should)|(want|endorse|recommend ?that you ?to) ?([try?(ing)] ?to) [be?(ing)]|[becom(e|(ing))] ?$V_VERY $ENT_OI_JBO_ShouldNotBeDescriptor)
){_intent='OI_JBO_ShouldNotBe'}{_intent += ENT_OI_JBO_ShouldNotBeDescriptor._entity}
;

RULE_OI_JBO_LikesThing = (
	(you ?(must|should) ?$V_ACTUALLY like|enjoy|love $ENT_OI_JBO_LikesThing)
){_intent='OI_JBO_Likes'}{_intent += ENT_OI_JBO_LikesThing._entity}
;

### RI_USR Rules ###
RULE_RI_USR_CanAction = (
    (can|may|could i|we ?$V_ACTUALLY $ENT_RI_USR_CanAction) |
    ((are we)|(am i) able|capable|allowed|permitted ?(to|of) ?$V_ACTUALLY $ENT_RI_USR_CanAction)
){_intent='RI_USR_Can'}{_intent += ENT_RI_USR_CanAction._entity}
;

RULE_RI_USR_HowCanAction = (
    (how can|do i|we ?$V_ACTUALLY $ENT_RI_USR_HowCanAction) |
    (how should i|we (try ?to)|(?(go about) trying ?to) ?$V_ACTUALLY $ENT_RI_USR_HowCanAction) |
    (what should i|we do ?(in order) ?to ?$V_ACTUALLY $ENT_RI_USR_HowCanAction) |
    (what steps can|should i|we take ?(in order) ?to ?$V_ACTUALLY $ENT_RI_USR_HowCanAction)
){_intent='RI_USR_HowCan'}{_intent += ENT_RI_USR_HowCanAction._entity}
;

RULE_RI_USR_IsDescriptor = (
    (am|are i|we ?$V_ACTUALLY ?$V_VERY $ENT_RI_USR_IsDescriptor) |
    ((do you think|believe)|(would you say) (i|we am|are)|i\'m|we\'re ?$V_VERY $ENT_RI_USR_IsDescriptor)
){_intent='RI_USR_Is'}{_intent += ENT_RI_USR_IsDescriptor._entity}
;

RULE_RI_USR_SeemsDescriptor = (
	(do i|we ?$V_ACTUALLY seem|look|apear ?(to be ?acting) ?$V_VERY $ENT_RI_USR_SeemsDescriptor) |
	(am|are i|we ?$V_ACTUALLY acting ?$V_VERY $ENT_RI_USR_SeemsDescriptor) |
	(do you ?$V_ACTUALLY feel ?(like|(as if|though)) i\'m|we\'re|(i|we am|are) ?$V_ACTUALLY ?$V_VERY $ENT_RI_USR_SeemsDescriptor)
){_intent='RI_USR_Seems'}{_intent += ENT_RI_USR_SeemsDescriptor._entity};

### OI_USR Rules ###
RULE_OI_USR_IsPlanningAction = (
    (we\'re|i\'m|(i|we am|are) ?(?$V_ACTUALLY going|gonna|planning|about ?to) ?$V_ACTUALLY $ENT_OI_USR_IsPlanningAction) |
    (i|we ?$V_ACTUALLY will|wanna|(want to) ?$V_ACTUALLY $ENT_OI_USR_IsPlanningAction)
){_intent='OI_USR_Is'}{_intent += ENT_OI_USR_IsPlanningAction._entity}
;

RULE_OI_USR_IsFriendsWithAgent = (
	($ENT_OI_USR_IsFriendsWithAgent ?(is|are) ?$V_ACTUALLY (my|our ?$V_ACTUAL ?best friend)|(friends with me|us)) |
	(i\'m|we\'re|(i|we am|are) ?$V_ACTUALLY friends with $ENT_OI_USR_IsFriendsWithAgent)
){_intent='OI_USR_IsFriendsWith'}{_intent += ENT_OI_USR_IsFriendsWithAgent._entity}
;

RULE_OI_USR_IsDescriptor = (
    (i|we ?(currently|also|$V_ACTUALLY) feel ?$V_VERY $ENT_OI_USR_IsDescriptor) |
    (i\'m|we\'re|(i|we am|are) ?(currently|also|$V_ACTUALLY) ?feeling ?(a|an|the) ?$V_VERY $ENT_OI_USR_IsDescriptor)
){_intent='OI_USR_Is'}{_intent += ENT_OI_USR_IsDescriptor._entity}
;

RULE_OI_USR_IsNotDescriptor = (
    ((i|we ?(currently|also|$V_ACTUALLY) don\'t|(do not) feel)|((we\'re|i\'m not)|(i|we ain\'t|(am|are not)|aren\'t) ?(currently|also|$V_ACTUALLY) ?feeling) ?$V_VERY $ENT_OI_USR_IsNotDescriptor)
){_intent='OI_USR_IsNot'}{_intent += ENT_OI_USR_IsNotDescriptor._entity}
;


RULE_OI_USR_DislikesAgent = (
    (i|we ?$V_ACTUALLY dislike|hate|despise|(don\'t|(do not) like) $ENT_OI_USR_DislikesAgent)
){_intent='OI_USR_Dislikes'}{_intent += ENT_OI_USR_DislikesAgent._entity}
;

RULE_OI_USR_ObservedAgent = (
    (i|we ?$V_ACTUALLY ?just ?have saw|seen|observed ?(a|an|the) ?$V_ACTUAL $ENT_OI_USR_ObservedAgent)
){_intent='OI_USR_Observed'}{_intent += ENT_OI_USR_ObservedAgent._entity}
;


RULE_OI_USR_LikesThing = (
    (i|we ?$V_ACTUALLY like|love $ENT_OI_USR_LikesThing)
){_intent='OI_USR_Likes'}{_intent += ENT_OI_USR_LikesThing._entity}
;

RULE_OI_USR_DislikesThing = (
    (i|we ?$V_ACTUALLY dislike|hate|despise|(don\'t|(do not) like) $ENT_OI_USR_DislikesThing)
){_intent='OI_USR_Dislikes'}{_intent += ENT_OI_USR_DislikesThing._entity}
;

RULE_OI_USR_IsSkilledAtThing = (
	(i\'m|we\'re|(i|we am|are) ?$V_VERY good|skilled|proficient|qualified|experienced|trained|(?an expert) ?(at|with|in|(to do)) $ENT_OI_USR_IsSkilledAtThing) |
	($ENT_OI_USR_IsSkilledAtThing (is|are ?$V_VERY easy)|(isn\'t|aren\'t|(is|are not) ?$V_VERY $V_CHALLENGING) for|to me|us) |
	((i|we think|consider|find)|(i\'ve|we\'ve found) ?that $ENT_OI_USR_IsSkilledAtThing (?(is|are|(to be)) ?$V_VERY easy)|(?just isn\'t|aren\'t|(is|are not)|(not to be) ?$V_VERY $V_CHALLENGING) ?(for|to me|us))
){_intent='OI_USR_IsSkilledAt'}{_intent+=ENT_OI_USR_IsSkilledAtThing._entity}
;

RULE_OI_USR_IsUnskilledAtThing = (
	(i\'m|we\'re|(i|we am|are) ?$V_VERY bad|terrible|(the ?absolute worst) ?(at|with|in|(to do)) $ENT_OI_USR_IsUnskilledAtThing) |
	(i|we ?$V_ACTUALLY suck|stink ?(at|with|in|(to do)) $ENT_OI_USR_IsUnskilledAtThing) |
	(i|we ?$V_ACTUALLY $V_CANNOT do $ENT_OI_USR_IsUnskilledAtThing ?(at all)) |
	($ENT_OI_USR_IsUnskilledAtThing (is|are ?$V_VERY impossible|$V_CHALLENGING)|(isn\'t|aren\'t|(is|are not) ?$V_VERY easy) ?(for|to me|us)) |
	((i|we think|consider|find)|(i\'ve|we\'ve found) ?that $ENT_OI_USR_IsUnskilledAtThing (?(is|are|(to be)) ?$V_VERY $V_CHALLENGING)|(?just isn\'t|aren\'t|(is|are not)|(not to be) ?$V_VERY easy) ?(for|to me|us))
){_intent='OI_USR_IsUnskilledAt'}{_intent+=ENT_OI_USR_IsUnskilledAtThing._entity}
;

RULE_OI_USR_HasThing = (
	((i|we ?$V_ACTUALLY have)|(i\'ve|we\'ve ?$V_ACTUALLY got) ?(a|an|the|some) $ENT_OI_USR_HasThing)
){_intent='OI_USR_Has'}{_intent += ENT_OI_USR_HasThing._entity}
;


### Loopmember ###

RULE_RI_LM_IsDescriptor = (
	(is $LOOPMEMBER ?$V_ACTUALLY ?$V_VERY $ENT_RULE_RI_LM_IsDescriptor) |
	((do you think|believe)|(would you say) ?that $LOOPMEMBER ?is ?$V_ACTUALLY ?$V_VERY $ENT_RULE_RI_LM_IsDescriptor) |
	(do|would you consider $LOOPMEMBER to ?$V_ACTUALLY be ?$V_VERY $ENT_RULE_RI_LM_IsDescriptor)
){_intent='RI_LM_Is'}{_intent+=ENT_RULE_RI_LM_IsDescriptor._entity}
{_loopmember=LOOPMEMBER._loopmember}
;

RULE_OI_LM_IsDescriptor = (
	($LOOPMEMBER is ?$V_ACTUALLY ?$V_VERY $ENT_OI_LM_IsDescriptor) |
	($V_I_THINK ?that $LOOPMEMBER ?is ?$V_ACTUALLY ?$V_VERY $ENT_OI_LM_IsDescriptor)
){_intent='OI_LM_Is'}{_intent+=ENT_OI_LM_IsDescriptor._entity}
{_loopmember=LOOPMEMBER._loopmember}
;

RULE_OI_LM_SeemsDescriptor = (
	(?$V_I_THINK $LOOPMEMBER ?$V_ACTUALLY [seem?s]|[appear?s]|[look?s] ?$V_VERY $ENT_OI_LM_SeemsDescriptor) |
	($LOOPMEMBER ?$V_ACTUALLY [act?s]|(?is ?$V_ACTUALLY acting) ?$V_VERY $ENT_OI_LM_SeemsDescriptor)
){_intent='OI_LM_Seems'}{_intent+=ENT_OI_LM_SeemsDescriptor._entity}
{_loopmember=LOOPMEMBER._loopmember}
;

### Other ###
RULE_OI_OTHER_IsDescriptor = (
