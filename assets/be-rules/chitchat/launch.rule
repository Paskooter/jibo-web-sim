### RA_JBO Rules ###

RULE_RA_JBO_DoAction = (
    (would|could|will you ?please ?(ever|usually|$V_ACTUALLY) $ENT_RA_JBO_DoAction) |
    (can|could i|we see ?the $ENT_RA_JBO_DoAction) |
    (?((let me|us)|let\'s) see you $w03 $ENT_RA_JBO_DoAction) |
	(?please ?((would you mind)|(are you willing ?to)) ?$V_ACTUALLY $ENT_RA_JBO_DoAction ?(for me|us)) |
    (i|we (?$V_ACTUALLY want)|(would ?$V_ACTUALLY like) you ?to ?please $ENT_RA_JBO_DoAction ?(for me|us)) |
	(do you have ?(a|an|any) $ENT_RA_JBO_DoAction ?(skill|app) ?installed) |
	(($V_CANYOU|(do you) ?$V_ACTUALLY $ENT_RA_JBO_DoAction) ~2)
){_mimId='RA_JBO_'}{_mimId += ENT_RA_JBO_DoAction._entity}
;


RULE_RA_JBO_DoStrictAction = (
    (would|could|will you ?please ?(ever|usually|$V_ACTUALLY) $ENT_RA_JBO_DoStrictAction ?please) |
    (can|could i|we see ?the $ENT_RA_JBO_DoStrictAction ?please) |
    (?((let me|us)|let\'s) see you $w03 $ENT_RA_JBO_DoStrictAction ?please) |
	(?please ?((would you mind)|(are you willing ?to)) ?$V_ACTUALLY $ENT_RA_JBO_DoStrictAction ?(for me|us) ?please) |
    (i|we (?$V_ACTUALLY want)|(would ?$V_ACTUALLY like) you ?to ?please $ENT_RA_JBO_DoStrictAction ?(for me|us) ?please) |
	(do you have ?(a|an|any) $ENT_RA_JBO_DoStrictAction ?(skill|app) ?installed) |
	(($V_CANYOU|(do you) ?$V_ACTUALLY $ENT_RA_JBO_DoStrictAction) ~4)
){_mimId='RA_JBO_'}{_mimId += ENT_RA_JBO_DoStrictAction._entity};

RULE_RA_JBO_MakeSoundThing =
(
	(what does|did ?(a|an|the) $ENT_RA_JBO_MakeSoundThing say) |
	(what $w03 ?(kind|type ?of) [sound?s]|[noise?s] ?[do?(es)] ?(a|an|the) $ENT_RA_JBO_MakeSoundThing [make?s]) |
	(?$V_DO_ACTION [mak(e|(ing))] ?(a|an|the) $ENT_RA_JBO_MakeSoundThing [sound?s]|[noise?s]) |
	(?$V_DO_ACTION $ENT_ANIMAL_SOUNDS|[talk?(ing)]|([mak(e|(ing))] $w03 [sound?s]|[noise?s]) like ?(a|an|the) $ENT_RA_JBO_MakeSoundThing)
){_mimId='RA_JBO_MakeSound'}{_mimId += ENT_RA_JBO_MakeSoundThing._entity}
|
(
	(?$V_DO_ACTION $ENT_ANIMAL_SOUNDS)
){_mimId='RA_JBO_MakeSound'}{_mimId += ENT_ANIMAL_SOUNDS._entity}
;

RULE_RA_JBO_DoHomeSecurity= (
	((watch|guard|protect) $w03 (my|our|this|the) (house|home|apartment|condo|room|building)) |
	((look|watch|check|(keep an eye) ?out) for $w03 ([stranger?s]|[burglar?s]|[prowler?s]|[intruder?s]|thieves|thief)) |
	(?((go|switch to)|do|be) $w03 (security|guard|protect|watch mode)|(security guard|camera|system)|(home security))
) {_mimId='RA_JBO_DoHomeSecurity'}
;
RULE_RA_JBO_Directions = (
	(can you $V_PROVIDE me|us directions <1.0>+$w<0.0>) |
	(do you have $* directions ) |
	( ?(can|could you) (help ?(me|us)) navigate) |
	(how long|(much time) (will|would it) take ?to walk ?to <1.0>+$w<0.0>) |
	(how [do?(es)]|would|should i|we|you|one|$V_PEOPLE get from|to <1.0>+$w<0.0>) |
	((do you know|remember)|(?$V_CANYOU [tell?(ing)] me|us) how ?to get from|to <1.0>+$w<0.0>)
){_mimId='RA_JBO_Directions'};
RULE_RA_JBO_GiveSkiReport = (
	(((do you know)|(can|could you (give|get|provide))) $w03 [ski?(ing)] ([condition?s]|[report?s])) |
	(((do you know)|(can|could you (give|get|provide))) $w03 ?snow [condition?s]|[report?s] $w03 [ski?(ing)]) |
	(what is|are $w03 [ski?(ing)] ([condition?s]|[report?s])) |
	(what is|are $w03 ([condition?s]|[report?s]) $w03 [ski?(ing)])
) {_mimId='RA_JBO_GiveSkiReport'}
;

RULE_RA_JBO_LeaveSantaCookiesAndMilk = (
	(?((can|will|could) you|we) ?please (set out)|leave $w03 cookies ?((and|with) milk) $w03 for $V_SANTA_CLAUS) |
	(?((can|will|could) you|we) (set out)|leave $w03 milk ?((and|with) cookies) $w03 for $V_SANTA_CLAUS) |
	(?((can|will|could) you|we) (set out)|leave $V_SANTA_CLAUS $w03 (cookies ?((and|with) milk))|(milk ?((and|with) cookies)))
) {_mimId='RA_JBO_LeaveSantaCookiesAndMilk'}
;

RULE_RA_JBO_MeetNonLM = (
	(((this|he|she is)|he\'s|she\'s|(these are)) $w03 $NON_LOOPMEMBER|(($V_ROMANTICPARTNER|$SS_FAMILY_MEMBER|(?my friend|friends|pal|buddy|buddies)) ?$NON_LOOPMEMBER)) |
	(introduce <1.0>?you<0.0> <1.0>?to<0.0> $w03 $NON_LOOPMEMBER|(($V_ROMANTICPARTNER|$SS_FAMILY_MEMBER|(?my friend|friends|pal|buddy|buddies)) ?$NON_LOOPMEMBER)) |
	(?(do you want to) meet|meat $w03 $NON_LOOPMEMBER|(($V_ROMANTICPARTNER|$SS_FAMILY_MEMBER|(?my friend|friends|pal|buddy|buddies)) ?$NON_LOOPMEMBER))
) {_mimId='RA_JBO_MeetNonLM'}
;

RULE_RA_JBO_MeetPet = (
	(((this|he|she is)|he\'s|she\'s) $w03 cat|dog|pet ?$NON_LOOPMEMBER) |
	(introduce <1.0>?you<0.0> <1.0>?to<0.0> $w03 cat|dog|pet ?$NON_LOOPMEMBER) |
	(?(do you want to) meet|meat $w03 cat|dog|pet ?$NON_LOOPMEMBER)
) {_mimId='RA_JBO_MeetPet'}
;
RULE_RA_JBO_MovieListings = (
	(?($V_CANYOU [list?(ing)]|[tell?(ing)]|[search?(ing)]|([look?(ing)] up)) movie showtimes|(show times)) |
	(what [movie?(?(\')s)] ?(is|are) $V_PLAYINGSHOWING )|
	(is $* movie $V_PLAYINGSHOWING )
){_mimId='RA_JBO_MovieListings'};
RULE_RA_JBO_OpeningClosingTimes = (
	((how late is|will)|(when|(what time) ?(is|will|does)) <1.0>+$w<0.0> [open?(s|(ing)|(ed))]|[clos(e|(es)|(ing)|(ed))])
){_mimId='RA_JBO_OpeningClosingTimes'};
RULE_RA_JBO_ReciteTwasNightBeforeChristmas = (
	(?(can|could you) ?please (recite|read) ?(the (poem|story)) twas the night before christmas)
){_mimId='RA_JBO_ReciteTwasNightBeforeChristmas'}
;
RULE_RA_JBO_SingChristmasSongUnknown = (
	(((do you know)|(?(can|will you) sing|play) $w03 ?(?a|the christmas|holiday ([song?s]|[carol?s])) $w03 ?the $ENT_KNOWN_SONGS ?[song?s]){_mimId='RI_JBO_Knows'}{_mimId+=ENT_KNOWN_SONGS._entity}{_mimId+='Song'}) |
	((
		((do you know)|(?(can|will you) sing|play) $w03 (?a|the christmas|holiday ([song?s]|[carol?s]))) |
		((do you know)|(?(can|will you) sing|play) $w03 (?a|the christmas|holiday ([song?s]|[carol?s])) $w03 ?the $ENT_UNKNOWN_SONGS ?[song?s]) |
		(do you know $w03 christmas (songs|song|carols|carol)) |
		(do you want to go ?christmas caroling|carolling) |
		(do you want to sing $w03 christmas (songs|carols)) |
		(?do you know $w03 $ENT_UNKNOWN_SONGS ?($w03 song)) |
		(play the $ENT_UNKNOWN_SONGS song) |
		(are you familiar ?with $w03 $ENT_UNKNOWN_SONGS) |
		([sing?(ing)] $w03 $ENT_UNKNOWN_SONGS)
	){_mimId='RA_JBO_SingChristmasSongUnknown'})
);
RULE_RA_JBO_Shuffle = (
	(what were you going ?to share|tell|show|say) |
	(what did you have|want ?to share|tell|show|say) |
	(you said you were going ?to share|tell|show|say (something ?(with|to me))|(me something) ) |
	(you said you had something $w03 ?to share|tell|show|say) |
	(share it) |
	(share $w03 fun|$V_INTERESTING)
){_mimId='RA_JBO_Shuffle'}
;
