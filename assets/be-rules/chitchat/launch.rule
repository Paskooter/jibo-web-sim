){_mimId='RA_JBO_SpellJibo'};

STRICT_RULE_RA_JBO_TalkToUser = (
	(talk to me ?jibo)|
	(let\'s talk ?jibo)|
	(?let\'s just talk ?jibo)|
	(?do you (want to)|wanna talk ?jibo) |
	(start talking ?jibo)|
	(i ?just (want to)|wanna have ?(a|some) conversation|words with you ?jibo)
){_mimId='RA_JBO_TalkToUser'}
;

STRICT_RULE_RA_JBO_SayHello = (
	(?$V_CANYOU [say?(ing)] hello|hi|hey ?(?in english) ?(?to $NON_LOOPMEMBER|$LOOPMEMBER|<1.0>$w<0.0> ?(?in english))) |
	(?$V_CANYOU [tell?(ing)] $NON_LOOPMEMBER|$LOOPMEMBER hello|hi|hey)
){_mimId='RA_JBO_SayHello'}
;


