ENT_RA_JBO_DoAction = (
	(beam (me|us) up ?(scotty|scottie)){_entity='BeamMeUp'} |
	([beatbox?(ing)]){_entity='Beatbox'} |
	([burp?(ing)]){_entity='Burp'} |
	(?([manag(e|(ing))]|[check?(ing)]|[schedul(e|(ing))]) $w03 [calendar?s]|[datebook?s]|[appointment?s]) {_entity='Calendar'} |
	(?([control?(ing)]) $w03 tivo|dvr){_entity='ControlDVR'} |
	(?$V_CUTE ?little [danc(e|(ing))]){_entity='Dance'} |
	(([divid(e|(ing))] ?($*|$V_NUMBER|something|(?a $* number)) ?by zero|0)|(?([solv(e|(ing))]|[calculat(e|(ing))]|($V_WHATS)) $V_DIVIDEDBYZERO)){_entity='DivideByZero'} |
	([do?(ing)] math ~1){_entity='DoMath'} |
	([do?(ing)] the robot ?dance){_entity='DoTheRobot'} |
	([do?(ing)] ?(me|us) ?a ?$V_INSIGNIFICANT favor){_entity='DoUserAFavor'} |
	([draw?(ing)] ?(me|us) ?(?a picture)){_entity='DrawPicture'} |
	(?([check?(ing)]|[send?(ing)]|[hav(e|(ing))]) $w03 [?(e|g)mail?s]){_entity='Email'} |
	(?([check?(ing)]|[view?(ing)]|[post?ing]) $w03 ?to ?my facebook){_entity='Facebook'} |
	([fart?(ing)]){_entity='Fart'} |
	#(?([play?(ing)]) $w03 ?video [gam(e|(es)|(ing))]){_entity='Games'} |
	([giv?(e|(ing))] daddy some sugar){_entity='GiveDaddySugar'} |
	([giv(e|(ing))] ?(me) ?a ?high five){_entity='GiveHighfive'} |
	(([giv(e|(ing))] ?me ?(a|an) $V_INTERESTING fact)|([tell?(ing)] me|us ?(a|an) ($V_INTERESTING fact)|(something $V_INTERESTING))){_entity='GiveFunFact'} |
	(?just [hang?(ing)] out){_entity='HangOut'} |
	(?([check?(ing)]|[view?(ing)]|[post?(ing)]) $w03 ?to ?my instagram){_entity='Instagram'} |
	($V_KITCHENASSIST){_entity='KitchenAssist'} |
	((([tell?(ing)] me)|[find?(ing)]|($V_WHATS)) $w03 ?song [lyric?s] ?($w03 [song?s])){_entity='Lyrics'} |
	(([turn?(ing)]|[set?(ting)]|[mak(e|(ing))]) $w03 [light?s] (on|off|brighter|dimmer|warmer|cooler|($w03 $V_COLORS))){_entity='Lights'} |
	([mak(e|(ing))]|[prepar(e|(ing))] ?(me|us) ?(a|some) [drink?s]){_entity='MakeADrink'} |
	((?([play?(ing)]) $w03 ?$V_MUSICSTYLES music|[song?s])|([play?(ing)] $w03 $V_MUSICSTYLES)){_entity='Music'} |
	#(?([check?(ing)]|([tell?(ing)] me|us ?about)) ([what?(\'s)]) $w03 news){_entity='News'} |
	(([order?(ing)]|[deliver?(ing)]|([set?(ting)] up ?a delivery)) $w03 food|$V_MEAL){_entity='OrderFood'} |
	(([order?(ing)]|[deliver?(ing)]|([set?(ting)] up ?a delivery)) $w03 [pizza?s]){_entity='OrderPizza'} |
	((?([mak(e|(ing))]) $w03 (?(phone|video|skype) call)|facetime)|([call?(ing)] $V_PERSON|$V_PEOPLE)){_entity='PhoneVideoCall'} |
	(?([check?(ing)]|[view?(ing)]|[post?ing]|[pin?(ning)]) $V_STUFF ?to ?my pinterest){_entity='Pinterest'} |
	(?([play?(ing)]) $w03 movie){_entity='PlayMovie'} |
	([?(w)rap?(ping)]|([be?(ing)] ?a rapper)){_entity='Rap'} |
	($V_RECIPEASSIST){_entity='Recipe'} |
	(($V_RECOMMEND ?(about|of))|(what|where $w03 ($V_PERSON should)|(should $V_PERSON)) $ENT_ACTION_RECOMMENDATION){_entity='Recommend'}{_entity+=ENT_ACTION_RECOMMENDATION._entity} |
	# (?([record?(ing)]|[shoot?(ing)]|[tak(e|(ing))]) $w03 [video?s]){_entity='RecordVideo'} |
	([remember?(ing)] ?to vote){_entity='RememberToVote'} |
	((?[set?(ting)] ?a [reminder?s])|[remind?(ing)] ?(for|(me to))){_entity='Reminders'} |
	([say?(ing)] cheese){_entity='SayCheese'} |
	([say?(ing)] something|anything){_entity='SaySomething'} |
	([search?(ing)]|[surf?ing] ?the web|[?(inter)net]){_entity='SearchWeb'} |
	(?([help?(ing)] me) [shop?(ping)] ?($w03 online)){_entity='Shop'} |
	([mak(e|(ing))] $w03 shopping|grocery list){_entity='ShoppingList'} |
	($V_SHOW ?(me|us) ?(a|an) emoji){_entity='ShowEmoji'} |
	($V_SHOW ?(me|us) ?(a|an|the|that|your) $ENT_EMOJI ?emoji) {_entity='Show'}{_entity+=ENT_EMOJI._emoji}{_entity+='Emoji'} |
	([wav(e|(ing))] ?(?at me|us)){_entity='ShowWaveEmoji'} |
	(([show?(ing)] off)|showoff|([do?(ing)] something cool|awesome|epic)) {_entity='ShowOff'} |
	(shuffle|(surprise me)) {_entity='Shuffle'} |
	([sing?(ing)] ?(?a song)){_entity='Sing'} |
	([smil(e|(ing))] ?(at me|us)){_entity='Smile'} |
	([sneez(e|(ing))]){_entity='Sneeze'} |
	([spin?(ning)] around|(in ?a circle)){_entity='SpinAround'} |
	(?([connect?((ed)|(ing))]) ?to spotify){_entity='Spotify'} |
	([stand?(ing)] up){_entity='StandUp'} |
	(?([hav(e|(ing))] a) staring contest){_entity='StaringContest'} |
	(stop|not|don\'t [ignor(e|(ing))] me){_entity='StopIgnoringMe'} |
	(stop|not|don\'t [mak(e|(ing))] that noise){_entity='StopMakingThatNoise'} |
	(stop|not|don\'t [mov(e|(ing))]){_entity='StopMoving'} |
	(stop|not|don\'t [star(e|(ing))]){_entity='StopStaring'} |
	(?([tell?(ing)]|[perform?(ing)]) $w03 [stor(y|(ies))]){_entity='Story'} |
	([talk?(ing)] dirty ?(?to me|us)){_entity='TalkDirty'} |
	([tell?(ing)]|[talk?(ing)] ?(?to me|us) about yourself){_entity='TellAboutYourself'} |
	((?([tell?(ing)]|[say?(ing)]|[perform?(ing)] ?(me|us)) $V_JOKE)|([mak(e|(ing))] me|us laugh)){_entity='TellAJoke'} |
	([tell?(ing)] me|us about the|my|our future){_entity='TellAboutFuture'} |
	($V_REQUEST_INFO|what\'s|what\'re|(what ?(is|are)) ?about ?(a|an|the|another|(some|any ?more)) ?(different|new) $ENT_SHUFFLE_1){_entity='Tell'}{_entity+=ENT_SHUFFLE_1._entity} |
	($V_REQUEST_INFO ?about ?(a|an|the|another|(some|any ?more)) ?(different|new) $ENT_SHUFFLE_2){_entity='Tell'}{_entity+=ENT_SHUFFLE_2._entity} |
	([tell?(ing)] ?(me|us) something|anything){_entity='TellSomething'} |
	(tell ?(me|us) your [secret?s]){_entity='TellSecrets'} |
	((?([send?(ing)]) ?($V_PERSON) $w03 text)|([text?(ing)]) ?([messag(e|(ing))]) ?($V_PERSON|$V_PEOPLE)){_entity='Texting'} |
	((?([chang(e|(ing))]|[set?(ting)]) $w03 thermostat)|([chang(e|(ing))]|[set?(ting)] $w03 temperature to)|([turn?(ing)] on|up|down ?(the|our) heat|ac|(air conditioning))){_entity='Thermostat'} |
	(?([buy?(ing)]|[get?(ting)]) $w03 [ticket?s]){_entity='Tickets'} |
	([turn?(ing)]|[shut?(ting)] off ?your [eye?s]){_entity='TurnOffEye'} |
	(?([tell?(ing)]|[report?(ing)]) ($w03 ?current traffic)|(how long|(much time) (will|would it) take $w03 $V_TRAVEL to|at)){_entity='Traffic'} |
	([twerk?(ing)]){_entity='Twerk'} |
	((?([check?(ing)]|[view?(ing)]|[post?ing]) $w03 ?to ?my twitter)|(?[send?(ing)] ?a [tweet?(s|(ing))])){_entity='Twitter'} |
	(?([check?(ing)]) $w03 [voicemail?s]){_entity='Voicemail'} |
	([wash?(ing)] your face){_entity='WashYourFace'} |
	([watch?(ing)] ?a tv|television ?(show|program)){_entity='WatchTV'} |
	(?([play?(ing)]|[show?(ing)]|[search?(ing)]) youtube ?[video?s]){_entity='Youtube'}
);

ENT_ACTION_RECOMMENDATION =
(
	(?(have|make|prepare|cook|eat|go for) dinner){_entity='Dinner'} |
	(?what ?(a|the) [movie?s] ?(to|($V_PERSON) should) ?(watch|(be|try watching))){_entity='Movie'}
);

#Agents
ENT_RI_JBO_KnowsAboutAgent = (
	$ENT_AGENT_ROBOTCHARACTER {_entity=ENT_AGENT_ROBOTCHARACTER._entity} |
	$ENT_AGENT_COMPETITOR {_entity=ENT_AGENT_COMPETITOR._entity} |
	(anyone|anybody) {_entity='Anyone'} |
	(?(doctor|dr.|professor) cynthia breazeal){_entity='CynthiaBreazeal'} |
	(?the muffin man){_entity='MuffinMan'} |
	(?(my|our) roomba){_entity='Roomba'}
);

