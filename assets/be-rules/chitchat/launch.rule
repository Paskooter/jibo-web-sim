###Partial recognition
ENT_PR = (
	(sweetie|cutie|buddy|bud|(little guy) ~2) {_entity='PetName'} |
	(blah ?blah ?blah ~3) {_entity='Blah'} |
	(boo ~2) {_entity='Boo'} |
	(ha ha ~2) {_entity='HaHa'} |
	(meow ~3) {_entity='Meow'} |
	(oh my god ~7) {_entity='OhMyGod'} |
	(omg ~2) {_entity='OMG'} |
	(poop ~3) {_entity='Poop'} |
	(robot ~4) {_entity='Robot'} |
	(say what ~6) {_entity='SayWhat'} |
	(testing ?(one|1 two|2 three|3) ~6) {_entity='Testing'} |
	($V_VULGARINSULT ~5) {_entity='VulgarInsult'} |
	($V_CURSEWORD ~2) {_entity='RandomCurse'} |
	(do it ~2) {_entity='DoIt'} |
	(just do it ~6) {_entity='JustDoIt'} |
	(nevermind ~8) {_entity='Nevermind'} |
	(reply ~4) {_entity='Reply'} |
	(sad ~2) {_entity='Sad'} |
	(what the $V_CURSEWORD ~8){_entity='WhatTheBleep'}
);

KU_PREFIXES= (
    (i (was ?$V_ACTUALLY saying|(trying to say))|(meant to say) $*) |
    ($V_CANYOU ?$V_ACTUALLY ?(tell ?(me|us) ?about) $*) |
    ($V_CANYOU ?$V_ACTUALLY access $*) |
    ($V_CANYOU ?$V_ACTUALLY get ?(me|us) $*) |
    ($V_CANYOU ?$V_ACTUALLY give ?(me|us) $*) |
    (do you ?$V_ACTUALLY have $*) |
    ((i ?$V_ACTUALLY want)|(i\'d|(i would) ?$V_ACTUALLY like) ?to $*) |
    (i ?$V_ACTUALLY wish ?to $*) |
    (i ?$V_ACTUALLY wish you $*)
~0.1);

