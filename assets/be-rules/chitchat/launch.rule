!use_equivalent_words = true;
TopRule =
(
	( $* $D_SCRIPTED_RESPONSES $* {intent=D_SCRIPTED_RESPONSES._intent} ) |
	( $* $D_SCRIPTED_RESPONSES_STRICT {intent=D_SCRIPTED_RESPONSES_STRICT._intent}) |
	( $* $D_SCRIPTED_RESPONSES_LOOPMEMBER $* {intent=D_SCRIPTED_RESPONSES_LOOPMEMBER._intent} {loopmember=D_SCRIPTED_RESPONSES_LOOPMEMBER._loopmember} ) |
	( $* ?$KU_PREFIXES $D_CHITCHAT $* {intent='gqa'} )
){skill='\@be/chitchat'}
;

### CHITCHAT DOMAIN: ###
D_CHITCHAT =
(
    $D_CHITCHAT_QUESTION_WORDS|are|did|do|does|is|was|can|
	($D_CHITCHAT_QUESTION_WORDS are|is|was|were) |
    ( ?(can you) tell ?(me|us) ?about ?($D_CHITCHAT_QUESTION_WORDS|$D_CHITCHAT_GQA_WHITELIST)) |
	$D_CHITCHAT_GQA_WHITELIST
);

D_CHITCHAT_QUESTION_WORDS = (
	[who?((\'s)|(\'re))]|[what?((\'s)|(\'re))]|[where?((\'s)|(\'re))]|
    [when?((\'s)|(\'re))]|[how?((\'s)|(\'re))]|[why?((\'s)|(\'re))]|
    [which?((\'s)|(\'re))]
);


D_CHITCHAT_GQA_WHITELIST =
(
	(how ?((do|would|should you|i)|(does one)) $* spell <1.0>+$w<0.0>) |
    (?(can you) ?please spell <1.0>+$w<0.0> ?(for me)) |
	#(?(how ?do ?(you|i)) say <1.0>+$w<0.0> ?in $V_LANGUAGES) |
    ((who)|(what person|[band?s]) sang|sings ?(?the song) <1.0>+$w<0.0>) |
    (who|(what person) directed ?(?the movie) <1.0>+$w<0.0>) |
    (who|(what person) wrote ?(?the movie|book|script|show|song|poem) <1.0>+$w<0.0>) |
    (who|(what person) performed $* ?(?in ?the movie|play|show|song) <1.0>+$w<0.0>) |
    (who|(what person) starred ?in $* ?(?the movie|play|show|song) <1.0>+$w<0.0>) |
    (who|what ?was $* release date) |
	(who $V_WONLOSTPLAYED $* $V_SPORTSGAME ) |
	(who|what won|recieved|(was nominated)|medaled $* [award?s]|[prize?s]|[nomination?s]|[championship?s]|$V_AWARDNAMES) |
	(did|are|is|will the <1.0>+$w<0.0> $V_WINLOSEPLAY) |
	($V_WHATS ?the $* score) |
	(when|(what $w03 time ?is)|(time $w03 ?when) $* sunrise|sunset|(sun $w03 [set?(ting)]|[ris(e|(ing))])) |
	((do|will i|we want|need)|(should i|we grab|bring|take) ?(a|an|the|$V_POSESSIVES) [umbrella?s]) |
	(will (it ?be)|(there be ?any) $V_WEATHER_TYPES ?$V_FUTURETIMES) |
	(is it ?(gonna|(going ?to)) ?be $V_WEATHER_TYPES ?$V_FUTURETIMES)
);


