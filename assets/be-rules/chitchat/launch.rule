	(which ?$V_TV channel plays|shows|has <1.0>+$w<0.0>) |
	(what time is|will $w03 show ?be $w03 on) |
	(what ?$V_TV channel is playing <1.0>+$w<0.0>) |
	(what\'s|(what is) on $V_TV)
){_mimId='RA_JBO_TVListings'}
;

### PR RULES ###

###Partial recognition

RULE_PR = (
	(sweetie|cutie|buddy|bud|(little guy) ~2) {_mimId='PR_PetName'} |
	(blah ?blah ?blah ~3) {_mimId='PR_Blah'} |
	(boo ~2) {_mimId='PR_Boo'} |
	((ha ha ?ha ?ha)|[haha?(ha)] ~2) {_mimId='PR_HaHa'} |
	(meow ~3) {_mimId='PR_Meow'} |
	(oh my god ~7) {_mimId='PR_OhMyGod'} |
	(omg ~2) {_mimId='PR_OMG'} |
	(poop ~3) {_mimId='PR_Poop'} |
	(robot ~4) {_mimId='PR_Robot'} |
	(say what ~2) {_mimId='PR_SayWhat'} |
	(testing ?(one|1 two|2 three|3) ~6) {_mimId='PR_Testing'} |
	(($V_VULGARINSULT ~5)|($V_CURSEWORD ~2)|(what the $V_CURSEWORD ~8)|(get lost ~6)|(go away ~5)|(nobody|(no one) likes you)) {_mimId='PR_VulgarInsult'} |
	((do it ~2)|(just do it ~6)|(go for it ~6)) {_mimId='PR_DoIt'} |
	((nevermind ~8)|(nvm ~2)|(forget it ~7)|(nothing ~6)) {_mimId='PR_Nevermind'} |
	(sad ~2) {_mimId='PR_Sad'}
);

STRICT_RULE_PR = (
	((are you) ~0.1){_mimId='PR_AreYou'} |
	((please) ~5){_mimId='PR_Please'}
);

### KU RULES ###
RULE_KU_AreYouAbleTo = ((are you able|capable ?(of|to))|(do you know how to)|(do you ever)|(can you) ?(do|(learn ?how ?to)) <1.0>+$w<0.0>){_mimId='KU_AreYouAbleTo'}
;
RULE_KU_AreYouAfraidOf = (
    (are you ?ever ?$V_VERY afraid|scared ?(of|about|by|around|(because ?of)) ?(a|an|the) <1.0>+$w<0.0>) |
    (do you ?ever feel|get ?$V_VERY afraid|scared ?(of|about|by|around|(because ?of)) ?(a|an|the) <1.0>+$w<0.0>) |
    (do|does ?the <1.0>+$w<0.0> ?$V_ACTUALLY scare you) |
	(do you think|believe ?the <1.0>+$w<0.0> ?(is|are) ?$V_ACTUALLY scary|frightening)
){_mimId='KU_AreYouAfraidOf'}
;
RULE_KU_AreYouGoodAt = (are you ?(any|$V_VERY) good|skilled ?at <1.0>+$w<0.0>){_mimId='KU_AreYouGoodAt'}
;
RULE_KU_AreYouMy =(are you my <1.0>+$w<0.0>){_mimId='KU_AreYouMy'}
;
RULE_KU_AreYouSaying = ((are you saying|(trying to say))|(did|do you ?(actually|really) mean ?(to say)|(did you ?just say)) <1.0>+$w<0.0>){_mimId='KU_AreYouSaying'}
;
RULE_KU_CanISeeThing = ($V_CAN_USER|(let me) [see?(ing)] <1.0>+$w<0.0>){_mimId='KU_CanISeeThing'}
;
RULE_KU_CanYouAccessThing = ($V_CANYOU|(do you have) [access?(ing)] <1.0>+$w<0.0>){_mimId='KU_CanYouAccessThing'}
;
RULE_KU_CanYouCleanThing = ($V_CANYOU [clean?(ing)]|[wash?(ing)] <1.0>+$w<0.0>){_mimId='KU_CanYouCleanThing'}
;
RULE_KU_CanYouGetUs = ($V_CANYOU [get?(ting)] us <1.0>+$w<0.0>){_mimId='KU_CanYouGetUs'}
;
RULE_KU_CanYouGiveMe = ($V_CANYOU [giv(e|(ing))] me <1.0>+$w<0.0>){_mimId='KU_CanYouGiveMe'}
;
RULE_KU_CanYouMoveThing = (
	((are you able|capable ?(of|to))|(do you know how ?to)|(do you ever)|(can you) ?(do|(learn ?how ?to)) [mov(e|(ing))] <1.0>+$w<0.0>)
){_mimId='KU_CanYouMoveThing'};
RULE_KU_CanYouSeeThing = ($V_CANYOU [see?(ing)] <1.0>+$w<0.0>){_mimId='KU_CanYouSeeThing'}
;
RULE_KU_DidITellYou = ((did i ?ever tell you)|(have i ?ever told you) <1.0>+$w<0.0>){_mimId='KU_DidITellYou'}
;
RULE_KU_DidYouHearThing = (did you hear <1.0>+$w<0.0>){_mimId='KU_DidYouHearThing'}
;
RULE_KU_DidYouKnowThat = ((did you know)|(were|are you aware) that <1.0>+$w<0.0>){_mimId='KU_DidYouKnowThat'}
;
RULE_KU_DoTheyLetYou =
	(( does $LOOPMEMBER ?ever $V_ALLOW you ) |( does your $* ?ever $V_ALLOW you ) |( are you ?ever ( allowed | permitted ) )|(do they let you)){_mimId='KU_DoTheyLetYou'}
;
RULE_KU_DoYouCelebrateThing = (do you celebrate <1.0>+$w<0.0>){_mimId='KU_DoYouCelebrateThing'}
;
RULE_KU_DoYouFeelThing = (do you feel <1.0>+$w<0.0>){_mimId='KU_DoYouFeelThing'}
;
RULE_KU_DoYouHaveThing = (do you have <1.0>+$w<0.0>){_mimId='KU_DoYouHaveThing'}
;
RULE_KU_DoYouLike = (do you like <1.0>+$w<0.0>){_mimId='KU_DoYouLike'}
;
RULE_KU_DoYouDislike = ( (do you ?$V_ACTUALLY hate|dislike|despise|detest|(not like) <1.0>+$w<0.0>) ){_mimId='KU_DoYouDislike'}
;
RULE_KU_DoYouLove = (do you love <1.0>+$w<0.0>){_mimId='KU_DoYouLove'}
;
RULE_KU_DoYouMissThing = (do you miss <1.0>+$w<0.0>){_mimId='KU_DoYouMissThing'}
;
RULE_KU_DoYouPrefer =(do|would you prefer|(have a preference) <1.0>+$w<0.0>){_mimId='KU_DoYouPrefer'}
;
RULE_KU_DoYouWantThing = (do you want <1.0>+$w<0.0>){_mimId='KU_DoYouWantThing'}
;
