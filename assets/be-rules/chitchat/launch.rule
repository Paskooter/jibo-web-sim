### Useful Vocab ###
V_2017 = ((last|(?the previous) [year?(?(\')s)])|2017|(twenty seventeen)|(two thousand seventeen));
V_2018 = ((this|(?the current) [year?(?(\')s)])|2018|(twenty eighteen)|(two thousand eighteen));
V_ABUSE = ([abus(e|(es)|(ed)|(ing))]|[hit?(s|(ting))]|[beat?(s|(ing))]|[hurt?(s|(ing))]|[punch?((es)|(ed)|(ing))]|[kick?(s|(ed)|(ing))]);
V_ABUSED = (abused|beaten|punched|kicked);
V_ACTUAL = (actual|real);
V_ACTUALLY = <1.0>(actually|already|really|reasonably|still|generally|literally|recently)<0.0>;
V_AFTERLIFE = ((life after death)|(?an afterlife)|(after life)|(heaven));
V_ALCOHOLIC_DRINKS = (alcohol|booze|liquor|whiskey|scotch|beer|wine|vodka|rum|cocktails);
V_ALEXA = (?([amazon?(?(\')s)]) alexa|echo);
V_ALLOW = let | allow | permit;
V_ALRIGHT = (good|okay|ok|alright|fine|decent);
V_ANNOYING =
(
	annoying|grouchy|(a pain in the $w03)|petulant|whiny|unlikable|
	bothersome|irritating|agravating
);
V_ASK = ([ask?(ing)]|([question?(ing)] ?me)|[inquir(e|(ing))]);
V_ATTENDEES = (people|person|[guest?s]|[visitor?s]|[participant?s]|[attendee?s]);
V_AWARDNAMES = (emmy|grammy|oscar|(acadamy [award?s])|(golden reel)|(golden [globe?s])|[olympic?s]);
V_AWESOME =
(
	awesome|amazing|fantastic|incredible|fascinating|wonderful|unbelievable|
	excellent|fabulous|astounding|cool|marvelous|phenomenal|superb|impressive|
	majestic|great|outstanding|extraordinary
);
V_BETTER = (better|funnier|sweeter|nicer|prettier|kinder|friendlier|smarter|wiser|bolder|stronger|(more $V_COMPLIMENT));
V_BOY = (boy | man | male);
V_BROKEN = (broken|(not working|[function((ing)|(al))])|busted|ruined|faulty|wrecked|(out of order));
V_CANCERS = (adenocarcinoma|adenocarcinoma|adenosarcoma|astrocytoma|astrocytoma|carcinoma|
    chondrosarcoma|ependymoma|glioblastoma|leukemia|liposarcoma|lymphoma|melanoma|mesenchymous|
    mesothelioma|myeloma|neuroblastoma|osteosarcoma|pheochromocytoma|pineoblastoma|rhabdomysosarcoma|
