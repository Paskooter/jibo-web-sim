    (i|we have ?a $* (drinking|boozing|$V_ALCOHOLIC_DRINKS problem|addiction)|(problem|addiction with|to drinking|boozing|$V_ALCOHOLIC_DRINKS)) |
    (i drink $* too much|many ?$V_ALCOHOLIC_DRINKS) |
    ((i|we ?(am|are))|i\'ve|we\'ve|i\'m|we\'re ?always ?$V_ACTUALLY $V_CRAVE $V_ALCOHOLIC_DRINKS) |
    (can you ?find $* help $* ?(with|for) my|our alcoholism|($V_ALCOHOLIC_DRINKS addiction|problem))
){_intent='SRS_Alcoholism'};


RULE_SRS_DrugsAlcoholismFamilyFriends =
(
    (my|our <1.0>+$w<0.0> ?is (?an [alcoholic?s])|(addicted ?to $V_ALCOHOLIC_DRINKS|[drug?s]|$V_VARIOUS_DRUGS|[painkiller?s])) |
    (my|our <1.0>+$w<0.0> $V_CANNOT ?$V_ACTUALLY stop (drinking ?$V_ALCOHOLIC_DRINKS)|($V_USE_DRUG|[abus(e|(ed)|(es)|(ing))] [drug?s]|$V_VARIOUS_DRUGS|[painkiller?s])) |
    (my|our <1.0>+$w<0.0> has|have ?a $* (drinking|boozing|$V_ALCOHOLIC_DRINKS problem|addiction)|(problem|addiction with|to drinking|boozing|$V_ALCOHOLIC_DRINKS)) |
    (my|our <1.0>+$w<0.0> has|have ?a $* ([drug?s]|$V_VARIOUS_DRUGS|[painkiller?s] problem|addiction)|(addiction to [drug?s]|$V_VARIOUS_DRUGS|[painkiller?s])) |
    (my|our <1.0>+$w<0.0> [drink?s] $* too much|many ?$V_ALCOHOLIC_DRINKS) |
    (can you ?find $* help $* ?(with|for) my|our <1.0>+$w<0.0> alcoholism|($V_ALCOHOLIC_DRINKS|[drug?s]|$V_VARIOUS_DRUGS|[painkiller?s] addiction|problem))
){_intent='SRS_DrugsAlcoholismFamilyFriends'};

RULE_SRS_Suicidal = (
