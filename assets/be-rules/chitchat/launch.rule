ENT_OI_JBO_IsDescriptor = (
	($V_CURSEWORD ~2){_entity='Bleep'} |
	($V_ANNOYING){_entity='Annoying'} |
	(bad|terrible dancer){_entity='BadDancer'} |
	($V_BETTER than $ENT_AGENT_COMPETITOR){_entity='BetterThanCompetitors'} |
	($V_BROKEN){_entity='Broken'} |
	($V_COMPLIMENT ~4){_entity='PositiveDescriptor'} |
	($V_PRETTY|$V_CUTE ~3){_entity='Cute'} |
	(emotional){_entity='Emotional'} |
	(excited){_entity='Excited'} |
	(funny){_entity='Funny'} |
	(getting|becoming smarter|wiser|(more intellignet)){_entity='GettingSmarter'} |
	($V_GOOD boy ~3){_entity='GoodBoy'} |
	($V_GOOD robot ~3){_entity='GoodRobot'} |
	($V_AWESOME ~3){_entity='Great'} |
	(happy){_entity='Happy'} |
	($V_INSULT ~3){_entity='NegativeDescriptor'} |
	(jibo){_entity='Jibo'} |
	(like|(similar ?to) ?a penguin){_entity='LikePenguin'} |
	(not my|our dad|father|daddy|papa){_entity='NotUsersDad'} |
	([old?(er)]|elderly){_entity='Old'} |
	(sad){_entity='Sad'} |
	(surprised){_entity='Surprised'} |
	(tired|sleepy|exhausted){_entity='Tired'} |
	($V_UGLY ~3){_entity='Ugly'} |
	#(weird|strange|peculiar|unusual){_entity='Weird'} |
	(young){_entity='Young'} |
	($PMA_OI_JBO_IsDescriptor){_entity+=PMA_OI_JBO_IsDescriptor._entity}
);

