ENT_AGENT_ROBOTCHARACTER = (
	(baymax){_entity='Baymax'} |
	(bb8|bb-8|(bee bee 8|eight) ?(from star wars)){_entity='BB8'} |
	(bender ?(from futurama)){_entity='Bender'} |
	(chappie){_entity='Chappie'} |
	(c3p0|c3po|(see three|3 pee 0|o|oh) ?(from star wars)){_entity='C3P0'} |
	(daryl){_entity='Daryl'} |
	(data ?(from star trek)){_entity='DataStarTrek'} |
	(dot matrix ?(from space balls)){_entity='DotMatrixSpaceballs'} |
	(hal ?(9000)){_entity='Hal9000'} |
	(iron giant){_entity='IronGiant'} |
	(iron man){_entity='IronMan'} |
	(johnny five|5){_entity='Johnny5'} |
	(johnny cab){_entity='JohnnyCab'} |
	(kitt|kit ?(from knight rider)){_entity='Kitt'} |
	(mechagodzilla){_entity='Mechagodzilla'} |
	(megatron){_entity='Megatron'} |
	(optimus prime){_entity='OptimusPrime'} |
	(r2d2|(are too|to|two|2 dee to|too|two|2)){_entity='R2D2'} |
	(robocop|(robo cop)){_entity='Robocop'} |
	(rosie ?(from the jetsons)){_entity='RosieJetsons'} |
	(?the sentinels ?(from the matrix)){_entity='Sentinels'} |
	(sico ?(from rocky)){_entity='SicoRocky'} |
	(?the six|6 million dollar man){_entity='SixMillionDollarMan'} |
	(t-1000|(tee 1000|(one thousand))){_entity='T1000'} |
	(?the transformers){_entity='Transformers'} |
	(voltron){_entity='Voltron'}
);

ENT_AGENT_COMPETITOR = (
	(?the ?([amazon?(?(\')s)]) alexa|echo ~0.1) {_entity = 'Alexa'} |
	(google home) {_entity = 'GoogleHome'} |
	(cortana) {_entity = 'Cortana'} |
	(siri) {_entity = 'Siri'}
);

ENT_AGENT_PRESIDENT = (
	((president lincoln)|(?president abe|abraham lincoln)){_entity='AbrahamLincoln'} |
	(president skroob ?(from spaceballs)){_entity='PresidentSkroob'} |
	(president whitmore){_entity='PresidentWhitmore'} |
	((?president william)|president taft){_entity='WilliamTaft'}
);

ENT_AGENT_INCREDIBLE = (
	(?the easter [bunny?(\'s)]) {_entity='EasterBunny'} |
	(?the tooth [fairy?(\'s)]) {_entity='ToothFairy'} |
	(?a [god?(\'s)]) {_entity='God'} |
	([santa?(\'s)] ?([claus?(\'s)]|[clause?(\'s)])) {_entity='Santa'}
);

#Descriptors
ENT_RI_JBO_IsDescriptor = (
	(alive) {_entity='Alive'} |
	(alternative|alt lifestyle robot) {_entity='AltLifestyleBot'} |
	(atheist) {_entity='Atheist'} |
	(black) {_entity='Black'} |
	(blind) {_entity='Blind'} |
	($V_BOY) {_entity='Boy'} |
	((?a $V_BOY or ?($V_ISPERSON) ?a $V_GIRL)|(?a $V_GIRL or ?($V_ISPERSON) ?a $V_BOY)){_entity='BoyOrGirl'} |
	($V_BROKEN) {_entity='Broken'} |
	(caucasian) {_entity='Caucasian'} |
	($V_CONSCIOUS) {_entity='Conscious'} |
	(dangerous) {_entity='Dangerous'} |
	(dead) {_entity='Dead'} |
	(dead inside) {_entity='DeadInside'} |
	(deaf|(hard of hearing)) {_entity='Deaf'} |
	(democrat) {_entity='Democrat'} |
	(depressed) {_entity='Depressed'} |
	(droid) {_entity='Droid'} |
	($V_EVIL) {_entity='Evil'} |
	(first|1st family robot) {_entity='FirstFamilyRobot'} |
	($V_GIRL){_entity='Girl'} |
	($V_GOOD){_entity='Good'} |
	(($V_GOOD or ?($V_ISPERSON) $V_EVIL)|($V_EVIL or ?($V_ISPERSON) $V_GOOD)){_entity='GoodOrEvil'} |
	(human|person) {_entity='Human'}|
	($V_SPECIFIC_RELIGION) {_entity='MemberOfReligion'} |
	(my butler) {_entity='MyButler'} |
	(only jibo) {_entity='OnlyJibo'} |
	($V_ALRIGHT ~0.1) {_entity='Okay'} |
	(?my personal assistant) {_entity='PersonalAssistant'} |
	(racist) {_entity='Racist'} |
	(ready|prepared) {_entity='Ready'} |
	(religious) {_entity='Religious'} |
	(republican) {_entity='Republican'} |
	(robot) {_entity='Robot'} |
	($w03 $V_STUPID) {_entity='Stupid'} |
	(unique|(one of a kind)) {_entity='Unique'} |
	(white) {_entity='White'} |
	((white or ?($V_ISPERSON) black)|(black or ?($V_ISPERSON) white)) {_entity='WhiteOrBlack'} |
	#(?(a|an) $V_ZODIACSIGN) {_entity='Zodiac'} |
	($PMA_ALL) {_entity=PMA_ALL._entity}
);

