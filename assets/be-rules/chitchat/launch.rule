!use_equivalent_words = true;
TopRule =
(
	( $* $D_CLOUD_SCRIPTED $* {intent='cloudScripted'} ) |
	( $* ?$KU_PREFIXES $D_GQA $* {intent='gqa'} ) |
	( $* ?$KU_PREFIXES $D_NEWS $* {intent='news'} ) |
	( $w03 $D_GQA_STRICT {intent='gqa'} ) |
	( $w03 $D_NEWS_STRICT {intent='news'} ) |
	( $* $D_EMOTION_QUERY_GENERAL $* {intent='emotionQuery'} ) |
	( $* $D_EMOTION_QUERY_SPECIFIC $* {intent='specificEmotionQuery'}{mimId=D_EMOTION_QUERY_SPECIFIC._mimId}{emotionName=D_EMOTION_QUERY_SPECIFIC._emotionName} ) |
	( $* $D_SCRIPTED_RESPONSES $* {intent='scripted'}{mimId=D_SCRIPTED_RESPONSES._mimId} ) |
	( $w03 $D_SCRIPTED_RESPONSES_STRICT {intent='scripted'}{mimId=D_SCRIPTED_RESPONSES_STRICT._mimId}) |
	( $* $D_SCRIPTED_RESPONSES_LOOPMEMBER $* {intent='scripted'}{mimId=D_SCRIPTED_RESPONSES_LOOPMEMBER._mimId} {loopmember=D_SCRIPTED_RESPONSES_LOOPMEMBER._loopmember} ) |
	( $w03 $D_SCRIPTED_RESPONSES_STRICT_LOOPMEMBER {intent='scripted'}{mimId=D_SCRIPTED_RESPONSES_STRICT_LOOPMEMBER._mimId} {loopmember=D_SCRIPTED_RESPONSES_STRICT_LOOPMEMBER._loopmember})
){skill='\@be/chitchat'}
;

### Cloud Scripted ###

D_CLOUD_SCRIPTED = (
	(<0.1>(can your|i|my)<0.0>) |
	(<0.1>(are|did|do|got|was you|your|i|my)<0.0>) |
	(($D_GQA_QUESTION_WORDS ?$D_CLOUD_SCRIPTED_COMMON_VERBS you|your|i|my|[jibo?s])~2.5) |
    (<0.3>($D_CLOUD_SCRIPTED_COMMON_VERBS you|your|i|my|we|our|[jibo?s])<0.0>) |
    (<0.4>(you $D_CLOUD_SCRIPTED_COMMON_VERBS|like|made|need|said|see|sound|want <1.0>+$w<0.0>)<0.0>) |
    (<0.4>(your $* $D_CLOUD_SCRIPTED_COMMON_VERBS <1.0>+$w<0.0>)<0.0>) |
    (<0.4>(i|we|(my|our $*) $D_CLOUD_SCRIPTED_COMMON_VERBS <1.0>+$w<0.0>)<0.0>) |
    (<0.4>(i\'m|i\'ve|you\'re|you\'ve|we\'re|we\'ve|let\'s <1.0>+$w<0.0>)<0.0>) |
    (<0.4>(not $* you)<0.0>) |
    (<0.9>(look)<0.0>) |
    (<0.9>(go to <1.0>+$w<0.0>)<0.0>) |
    (<0.9>(be a <1.0>+$w<0.0>)<0.0>) |
    (<0.9>(make|run|start|create|download|share|connect|watch|guard|update <1.0>+$w<0.0>)<0.0>)
);

D_CLOUD_SCRIPTED_COMMON_VERBS = (
    ain\'t|am|[are?(n\'t)]|[can?(n\'t)]|[could?(n\'t)]|[did?(n\'t)]|
    [do?(es)?(n\'t)]|got|[ha(s|(ve))?(n\'t)]|[is?(n\'t)]|[should?(n\'t)]|
    [was?(n\'t)]|[were?(n\'t)]|will|[would?(n\'t)]|won\'t
);


### GENERAL QUESTION ANSWER DOMAIN: ###
D_GQA =
(
    $D_GQA_QUESTION_WORDS|are|did|do|does|is|was|can|
	($D_GQA_QUESTION_WORDS are|is|was|were) |
    ( ?(can you) tell ?(me|us) ?about ?($D_GQA_QUESTION_WORDS|$D_GQA_WHITELIST)) |
	(do you know $D_GQA_QUESTION_WORDS) |
	$D_GQA_WHITELIST
);

D_GQA_QUESTION_WORDS = (
	[who?((?(\')s)|(?(\')re))]|[what?((?(\')s)|(?(\')re))]|
	[where?((?(\')s)|(?(\')re))]|[when?((?(\')s)|(?(\')re))]|
	[how?((?(\')s)|(?(\')re))]|[why?((?(\')s)|(?(\')re))]|
	[which?((?(\')s)|(?(\')re))]
);


D_GQA_WHITELIST =
(
	(do you know <1.0>+$w<0.0>) |
	(look up <1.0>+$w<0.0>) |
	(tell|give ?(me|us) $w03 weather) |
	(what\'s|what ?is $w03 weather) |
	(how ?((do|would|should you|i)|(does one)) $* spell <1.0>+$w<0.0>) |
    (?(can you) ?please spell <1.0>+$w<0.0> ?(for me)) |
    ((who)|(what person|[band?s]) sang|sings ?(?the song) <1.0>+$w<0.0>) |
    (who|(what person) [direct?(s|(ed))] ?(?the movie) <1.0>+$w<0.0>) |
    (who|(what person) wrote ?(?the movie|book|script|show|song|poem) <1.0>+$w<0.0>) |
    (who|(what person) [perform?(s|(ed))] $* ?(?in ?the movie|play|show|song) <1.0>+$w<0.0>) |
    (who|(what person) [star?(s|(red))] ?in $* ?(?the movie|play|show|song) <1.0>+$w<0.0>) |
    (who|what ?was $* release date) |
	(who $V_WONLOSTPLAYED $* $V_SPORTSGAME ) |
	(who|what won|received|(was nominated)|medaled $* [award?s]|[prize?s]|[nomination?s]|[championship?s]|$V_AWARDNAMES) |
	(did|are|is|will the <1.0>+$w<0.0> $V_WINLOSEPLAY) |
	($V_WHATS ?the $* score) |
	(when|(what $w03 time ?is)|(time $w03 ?when) $* sunrise|sunset|(sun $w03 [set?(ting)]|[ris(e|(ing))])) |
	(do|will i|we want|need $w03 [umbrella?s]) |
	(should i|we grab|bring|take $w03 [umbrella?s]) |
	(will (it ?be)|(there be ?any) $V_WEATHER_TYPES ?$V_FUTURETIMES) |
	(is it ?(gonna|(going ?to)) ?be $V_WEATHER_TYPES ?$V_FUTURETIMES) |
	([what?(\'s)] [today?(\'s)] weather|forecast|temperature|humidity) |
	(what [time?s] ?($w03 is|are|will) $* (?$V_SPORTS $V_SPORTSGAME)|$V_SPORTS|([play?(s|(ing))] $w03 ?$V_SPORTS)) |
	(define|([what?(?(\')s)] ?is ?the definition ?of) <1.0>+$w<0.0>) |
	([add?((ing)|(ed))]|[subtract?((ing)|(ed))]|[multipl(y|(ing)|(ed))]|[divid(e|(ing)|(ed))] $* $V_NUMBER) |
	($V_NUMBER $w03 plus|minus|divided|multiplied|times $w03 $V_NUMBER) |
	([what?(\'s)] ?is ?the volume of a|an|the <1.0>+$w<0.0> ) |
	([what?(\'s)] ?is ?the volume ?of $w03 $SS_SHAPE) |
	(when is the u.s.|us|british|australian open) |
	(([what?(\'s)] (?is ?the date)|(day|date ?is) $w03 $V_FUTURETIMES|$V_RECENT_PAST) ~3) |
	((?(do you know) ([when?(?(\')s)] ?((will it)|(is it)))|([what?(?(\')s)]|which $w03 day|date)|(how long ?until) $w03 (independence day $w03 $factory:country)|($SS_NATIONALITY independence day)) ~1) |
	((is|will (independence day $w03 $factory:country)|($SS_NATIONALITY independence day) ?be $V_FUTURETIMES) ~1) |
	([who?(\'s)] ?(is|was) $w03 best actor|actress $w03 $YEAR) |
	($V_WHATS (ash wednesday)|(good friday)|(fat tuesday))
);

D_GQA_STRICT = (weather);

### NEWS ###
D_NEWS =
(
	([new?s] [headline?s]) |
	(tell|give|read|play ?(me|us) $w03 [new?s] ?($w03 $V_RECENT_PAST)) |
	([what?(?(\')s)] ?is $w03 news ?($w03 $V_RECENT_PAST)) |
	([what?(?(\')s)] ?is $w03 the new ?($w03 $V_RECENT_PAST)) |
	([what?(?(\')s)] ?is new ?(in|about) ?the world ?($w03 $V_RECENT_PAST)) |
	([what?(?(\')s)] $w03 ?is happening|(going on) ?in ?the world|news ?($w03 $V_RECENT_PAST)) |
	([what?(?(\')s)] $w03 happened ?in ?the world|news ?($w03 $V_RECENT_PAST)) |
	([what?(?(\')s)] [event?s] $w03 ?(has|have) happened ?($w03 $V_RECENT_PAST)) |
	([what?(?(\')s)] ?is going ?on ?(?in ?the world|news) $w03 $V_RECENT_PAST)
);

D_NEWS_STRICT = (news);

### EMOTION DOMAIN: ###

D_EMOTION_QUERY_GENERAL =
(
	([how?(\')?s] ?(is|has) (it going|hanging)|($* doing)|(your $V_TIME_RELATIVE ?(going|been))) |
	(how\'re|(how are) you ?(doing|feeling) ?(?this $w03 $V_TIME_RELATIVE)) |
	(how do you feel ?(?this $w03 $V_TIME_RELATIVE))
);

D_EMOTION_QUERY_SPECIFIC =
(
	($RULE_RI_JBO_IsEmotion {_mimId=RULE_RI_JBO_IsEmotion._mimId}{_emotionName=RULE_RI_JBO_IsEmotion._emotionName}) |
	($RULE_OI_JBO_IsEmotion {_mimId=RULE_OI_JBO_IsEmotion._mimId}{_emotionName=RULE_OI_JBO_IsEmotion._emotionName}) |
	($RULE_OI_JBO_IsNotEmotion {_mimId=RULE_OI_JBO_IsNotEmotion._mimId}{_emotionName=RULE_OI_JBO_IsNotEmotion._emotionName})
)
#Rename Emotions according to Emotion System labels
{%
	switch (this._emotionName) {
		case 'Afraid': this._emotionName = 'Frustrated'; break;
		case 'Amused': this._emotionName = 'Joyful'; break;
		case 'Angry': this._emotionName = 'Frustrated'; break;
		case 'Annoyed': this._emotionName = 'Frustrated'; break;
		case 'Anxious': this._emotionName = 'Uncertain'; break;
		case 'Confused': this._emotionName = 'Uncertain'; break;
		case 'Embarrassed': this._emotionName = 'Uncertain'; break;
		case 'Happy': this._emotionName = 'Joyful'; break;
		case 'Jealous': this._emotionName = 'Frustrated'; break;
		case 'Lonely': this._emotionName = 'Sad'; break;
		case 'Proud': this._emotionName = 'Confident'; break;
	}
%}

;

RULE_RI_JBO_IsEmotion = (
    (are you ?($V_ACTUALLY|also) ?feeling ?(a|an|the) ?$V_VERY $PMA_EMOTIONS) |
    (do|would you ?($V_ACTUALLY|also) consider|(think ?of) yourself ?as ?(a|an|the) ?$V_VERY $PMA_EMOTIONS) |
    (do you ?($V_ACTUALLY|also) think you\'re|(you are) ?($V_ACTUALLY|also) ?(a|an|the) ?$V_VERY $PMA_EMOTIONS) |
	(do you ?($V_ACTUALLY|also) feel ?$V_VERY $PMA_EMOTIONS )
){_mimId='RI_JBO_Is'}{_mimId += PMA_EMOTIONS._entity}{_emotionName=PMA_EMOTIONS._entity}
;

RULE_OI_JBO_IsEmotion = (
    (?$V_I_THINK you ?($V_ACTUALLY|also) are ?($V_ACTUALLY|also) ?(feeling|being) ?(a|an|the) ?$V_VERY $PMA_EMOTIONS) |
    (?$V_I_THINK you\'re ?($V_ACTUALLY|also) ?(a|an|the) ?$V_VERY $PMA_EMOTIONS) |
	(?$V_I_THINK you ?($V_ACTUALLY|also) [feel?s] ?(a|an|the) ?$V_VERY $PMA_EMOTIONS) |
	(?$V_I_THINK you [look?s]|[seem?s]|[appear?s] ?((like|(as though) ?(you|they are))|(to be) ?(a|an|the)) ?$V_VERY $PMA_EMOTIONS ) |
	(i ?$V_ACTUALLY feel like|(as though) you ?$V_ACTUALLY are ?$V_VERY $PMA_EMOTIONS) |
	((you are)|[you?(?(\')re)] ?$V_ACTUALLY acting ?$V_VERY $PMA_EMOTIONS)
){_mimId='OI_JBO_Is'}{_mimId += PMA_EMOTIONS._entity}{_emotionName=PMA_EMOTIONS._entity}
;

RULE_OI_JBO_IsNotEmotion = (
    (?$V_I_THINK you ?($V_ACTUALLY|also) ain\'t|aren\'t|(are not) ?($V_ACTUALLY|also) ?(feeling|being) ?(a|an|the) ?$V_VERY $PMA_EMOTIONS) |
    (?$V_I_THINK you\'re not ?($V_ACTUALLY|also) ?(a|an|the) ?$V_VERY $PMA_EMOTIONS) |
	(?$V_I_THINK you never|don\'t|(do not) feel ?$V_VERY $PMA_EMOTIONS)
){_mimId='OI_JBO_IsNot'}{_mimId += PMA_EMOTIONS._entity}{_emotionName=PMA_EMOTIONS._entity}
;


