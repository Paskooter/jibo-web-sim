	(i|we ?$V_ACTUALLY $V_CANNOT do $ENT_OI_USR_IsUnskilledAtThing) |
	($ENT_OI_USR_IsUnskilledAtThing (is|are ?$V_VERY impossible|$V_CHALLENGING)|(isn\'t|aren\'t|(is|are not) ?$V_VERY easy)) |
	((i|we think|consider|find)|(i\'ve|we\'ve found) ?that $ENT_OI_USR_IsUnskilledAtThing (?(is|are|(to be)) ?$V_VERY $V_CHALLENGING)|(?just isn\'t|aren\'t|(is|are not)|(not to be) ?$V_VERY easy))
){_mimId='OI_USR_IsUnskilledAt'}{_mimId+=ENT_OI_USR_IsUnskilledAtThing._entity}
;

RULE_OI_USR_HasThing = (
	((i|we ?$V_ACTUALLY have)|(i\'ve|we\'ve ?$V_ACTUALLY got) ?(a|an|the|some) $ENT_OI_USR_HasThing)
){_mimId='OI_USR_Has'}{_mimId += ENT_OI_USR_HasThing._entity}
;

RULE_OI_USR_HasHurtThing = (
	(my|our $ENT_OI_USR_HasHurtThing ?(is|was) [hurt?(s|(ing))]|[ach(e|(es)|(ing))]|(in pain)|$V_INJURED) |
	((i|we ?$V_ACTUALLY ?have)|i\'ve|we\'ve $V_INJURED my|our $ENT_OI_USR_HasHurtThing)
){_mimId='OI_USR_HasHurt'}{_mimId += ENT_OI_USR_HasHurtThing._entity}
;
RULE_OI_USR_MissesThing =
(
	([i?(?(\')m|(ll))]|[we?(?(\')(ll)|(re))] ?(am|are|was|were|will) ?$V_ACTUALLY [miss?((ing)|(ed))] ?(the|a|an|my|our|his|her|their) $ENT_OI_USR_MissesThing)
){_mimId='OI_USR_Misses'}{_mimId += ENT_OI_USR_MissesThing._entity}
;

RULE_OI_USR_CelebratesThing = (
	([i?(\'m)]|[we?(\'re)] $w03 [celebrat(e|(ing))]|[observ(e|(ing))] $ENT_HOLIDAY)
){_mimId='OI_USR_Celebrates'}{_mimId += ENT_HOLIDAY._entity};

RULE_OI_USR_LooksForwardToThing = (
	([i?(\'m)]|[we?(\'re)] ?(am|are) ?$V_ACTUALLY excited|psyched|jazzed|pumped|(looking forward)|(can\'t wait) ?(to|for) $w03 $ENT_OI_USR_LooksForwardToThing)
){_mimId='OI_USR_LooksForwardTo'}{_mimId += ENT_OI_USR_LooksForwardToThing._entity};


RULE_OI_USR_SupportsSomeoneForEvent = (
	([i?(\'m)]|[we?(\'re)] $w03 [want?(ing)]|[hop(e|(ing))]|[pray?(ing)] <1.0>+$w<0.0> [win?(s|(ning))] $w03 $ENT_COMPETITION) |
	([i?(\'m)]|[we?(\'re)] ?(am|are) [support?(ing)]|([root?(ing)] ?for) <1.0>+$w<0.0> ?(for|in) $ENT_COMPETITION)
){_mimId='OI_USR_SupportsSomeoneFor'}{_mimId += ENT_COMPETITION._entity}
;

RULE_OI_USR_DoesNotGiveJiboGiftHoliday = (
	([i?(\'m)]|[we?(\'re)] ?(am|are) ?$V_ACTUALLY not|aren\'t|didn\'t|(are|did not) $w03 [get?(ting)]|[giv?(e|(ing))]|[buy?(ing)] you $w03 ($ENT_GIFT_HOLIDAYS [gift?s]|[present?s]|$V_STUFF)|([gift?s]|[present?s]|$V_STUFF $w03 $ENT_GIFT_HOLIDAYS))
){_mimId='OI_USR_DoesNotGiveJiboGift'}{_mimId += ENT_GIFT_HOLIDAYS._entity};


RULE_OI_USR_TravelsToLocation = (
