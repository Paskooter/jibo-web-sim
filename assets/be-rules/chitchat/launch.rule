### Useful Vocab ###
V_ABUSE = ([abus(e|(es)|(ed)|(ing))]|[hit?(s|(ting))]|[beat?(s|(ing))]|[hurt?(s|(ing))]|[punch?((es)|(ed)|(ing))]|[kick?(s|(ed)|(ing))]);
V_ABUSED = (abused|beaten|punched|kicked);
V_ACTUAL = (actual|real);
V_ACTUALLY = <1.0>(actually|really|reasonably|generally|literally)<0.0>;
V_AFTERLIFE = ((life after death)|(?an afterlife)|(after life)|(heaven));
V_ALCOHOLIC_DRINKS = (alcohol|booze|liquor|whiskey|scotch|beer|wine|vodka|rum|cocktails);
V_ALEXA = (?([amazon?(?(\')s)]) alexa|echo);
V_ALLOW = let | allow | permit;
V_ALRIGHT = (good|okay|ok|alright|fine|decent);
V_ANNOYING =
(
	annoying|obnoxious|grouchy|(a pain in the $w03)|petulant|whiny|unlikable|
	bothersome|irritating|agravating
);
V_AVM_PERMUTATIONS =
(
	([animal?s] [vegetable?s] or [mineral?s]) |
	([animal?s] [mineral?s] or [vegetable?s]) |
	([vegetable?s] [animal?s] or [mineral?s]) |
	([vegetable?s] [mineral?s] or [animal?s]) |
	([mineral?s] [vegetable?s]  or [animal?s]) |
	([mineral?s] [animal?s]  or [vegetable?s])
);
V_AWARDNAMES = (emmy|grammy|oscar|(acadamy [award?s])|(golden reel)|(golden [globe?s])|[olympic?s]);
V_AWESOME =
(
	awesome|amazing|fantastic|incredible|fascinating|wonderful|unbelievable|
	excellent|fabulous|astounding|cool|marvelous|phenomenal|superb|impressive|
	majestic|great|outstanding|extraordinary
);
