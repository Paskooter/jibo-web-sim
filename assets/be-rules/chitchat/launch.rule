#### Scripted Response Stems ###

### RI_JBO Rules###
#Actions
RULE_RI_JBO_CanAction = (
    (can|do|could|would you ?($V_ACTUALLY|usually|ever|please) ?(learn ?how ?to) $ENT_RI_JBO_CanAction) |
    (are you ?($V_ACTUALLY|usually|ever) able|capable ?(to|of) ?$V_ACTUALLY ?([learn?(ing)] ?how ?to) ?$V_ACTUALLY $ENT_RI_JBO_CanAction) |
	(do you ?$V_ACTUALLY know how to $ENT_RI_JBO_CanAction)
){_mimId='RI_JBO_Can'}{_mimId += ENT_RI_JBO_CanAction._entity}
;

RULE_RI_JBO_CanStrictAction = (
    (can|do you ?(?$V_ACTUALLY|usually) ?(learn ?how ?to) $ENT_RI_JBO_CanStrictAction) |
    (are you ?(?$V_ACTUALLY|usually) able|capable ?(to|of) ?$V_ACTUALLY ?([learn?(ing)] ?$V_ACTUALLY) $ENT_RI_JBO_CanStrictAction) |
	(do you ?$V_ACTUALLY know how ?to $ENT_RI_JBO_CanStrictAction)
){_mimId='RI_JBO_Can'}{_mimId += ENT_RI_JBO_CanStrictAction._entity}
;

RULE_RI_JBO_HowCanAction = (
    (how do|can you ?$V_ACTUALLY $ENT_RI_JBO_HowCanAction) |
    (how are you ?$V_ACTUALLY (able ?to)|(capable ?of) ?$V_ACTUALLY $ENT_RI_JBO_HowCanAction) |
    (how is it ?$V_ACTUALLY possible|feasible|conceivable for you ?to ?$V_ACTUALLY $ENT_RI_JBO_HowCanAction) |
	(how is it that you ?$V_ACTUALLY $ENT_RI_JBO_HowCanAction)
){_mimId='RI_JBO_HowCan'}{_mimId += ENT_RI_JBO_HowCanAction._entity}
;

RULE_RI_JBO_HowCanStrictAction = (
    (how do|can you ?$V_ACTUALLY $ENT_RI_JBO_HowCanStrictAction) |
    (how are you ?$V_ACTUALLY (able ?to)|(capable ?of) ?$V_ACTUALLY $ENT_RI_JBO_HowCanStrictAction) |
    (how is it ?$V_ACTUALLY possible|feasible|conceivable for you ?to ?$V_ACTUALLY $ENT_RI_JBO_HowCanStrictAction) |
	(how is it that you ?$V_ACTUALLY $ENT_RI_JBO_HowCanStrictAction)
){_mimId='RI_JBO_HowCan'}{_mimId += ENT_RI_JBO_HowCanStrictAction._entity}
;

RULE_RI_JBO_HowCanRecognizeVoices = (
	(how does ?your [voice?s]|audio [rec?(ognition)] ?(system|software|program) [work?s]) |
	(how do|did|can|could you know|tell who i am) |
	(how do|did|can|could you know|tell ((it was)|it\'s|(it is)) me|i)
){_mimId='RI_JBO_HowCanRecognizeVoices'}
;

RULE_RI_JBO_HowCanRecognizeFaces = (
	how does ?your face|facial [rec?(ognition)] ?(system|software|program) [work?s]
){_mimId='RI_JBO_HowCanRecognizeFaces'}
;

RULE_RI_JBO_LikesStrictThing = (
    (do|did you ?$V_ACTUALLY like|love|adore|enjoy ?(a|an|the) ?$V_VERY $ENT_RI_JBO_LikesStrictThing) |
    (don\'t you ?just like|love ?(a|an|the) ?$V_VERY $ENT_RI_JBO_LikesStrictThing ?right) |
    (you ?just like|love|adore|enjoy  ?(a|an|the) ?$V_VERY $ENT_RI_JBO_LikesStrictThing ?(right|(don\'t you))) |
	(are you happy|excited|proud ((?that you can)|((?that you are)|(about being)|(to ?be) ?$V_ACTUALLY able|capable ?(to|of)))|(to ?be) $ENT_RI_JBO_LikesStrictThing)
){_mimId='RI_JBO_Likes'}{_mimId += ENT_RI_JBO_LikesStrictThing._entity}
;

RULE_RI_JBO_HasDoneAction = (
	(have|did you ?$V_ACTUALLY ?ever ?$V_ACTUALLY ?done $ENT_RI_JBO_HasDoneAction )
){_mimId='RI_JBO_Has'}{_mimId += ENT_RI_JBO_HasDoneAction._entity}
;
RULE_RI_JBO_HasFlu = (
	(do you have ?a cold|flu|virus|influenza|allergy|sickness) |
	(are you contagious|infected)
){_mimId='RI_JBO_HasFlu'}
;
RULE_RI_JBO_WhyCannotAction = (
    (why (can\'t|don\'t|won\'t you)|(can|do|will you not) ?ever $ENT_RI_JBO_WhyCannotAction) |
    (why (aren\'t you)|(are you not) ?((able ?to)|(capable ?of)) ?ever $ENT_RI_JBO_WhyCannotAction) |
    (why are you (unable ?to)|(incapable ?of) $ENT_RI_JBO_WhyCannotAction)
){_mimId='RI_JBO_WhyCannot'}{_mimId += ENT_RI_JBO_WhyCannotAction._entity}
;
RULE_RI_JBO_WhyCannotWork = (
	(work for me)
){_mimId='RI_JBO_WhyCannotWork'};

RULE_RI_JBO_IsPerformingAction = (
    (are|do|did|have|were you ?$V_ACTUALLY ?been ?([tr((y?(ing))|(ied))] ?to) $ENT_RI_JBO_IsPerformingAction ?(soon|recently|(?right now)))
){_mimId='RI_JBO_Is'}{_mimId += ENT_RI_JBO_IsPerformingAction._entity}
;



RULE_RI_JBO_WantsToAction = (
	(?do you ?$V_ACTUALLY want|wanna|wish ?you ?(could|(were able|capable ?(to|of))) ?to ?$V_ACTUALLY $ENT_RI_JBO_WantsToAction) |
	(would you like|enjoy|prefer ?to ?(?be able|capable ?(to|of)) ?$V_ACTUALLY $ENT_RI_JBO_WantsToAction)
){_mimId='RI_JBO_WantsTo'}{_mimId += ENT_RI_JBO_WantsToAction._entity}
;


#Agents
RULE_RI_JBO_KnowsAboutAgent = (
    ((who is ?(doctor|dr.|professor) cynthia breazeal|brazil){_mimId='RI_JBO_KnowsAboutCynthiaBreazeal'})
)|((
    (?do you know ?about $ENT_RI_JBO_KnowsAboutAgent) |
    (do you know who|what $ENT_RI_JBO_KnowsAboutAgent is|are) |
    (have you heard ?(of|about) $ENT_RI_JBO_KnowsAboutAgent) |
    (are you familiar ?with $ENT_RI_JBO_KnowsAboutAgent|(who|what $ENT_RI_JBO_KnowsAboutAgent is))
){_mimId='RI_JBO_KnowsAbout'}{_mimId += ENT_RI_JBO_KnowsAboutAgent._entity})
;

RULE_RI_JBO_HasMetAgent = (
    (have|did you ?ever ?$V_ACTUALLY met|meet $ENT_RI_JBO_HasMetAgent ?yet) |
    (have you and $ENT_RI_JBO_HasMetAgent ?ever ?$V_ACTUALLY meet|met ?(each other) ?yet) |
    (have|did|were you and $ENT_RI_JBO_HasMetAgent ?$V_ACTUALLY ?(been|get) introduced ?(?to each other) ?yet) |
    (have i|we ?$V_ACTUALLY introduced you to $ENT_RI_JBO_HasMetAgent ?yet)
){_mimId='RI_JBO_HasMet'}{_mimId += ENT_RI_JBO_HasMetAgent._entity}
;

RULE_RI_JBO_IsRelatedToAgent = (
	(are you related ?to $ENT_RI_JBO_IsRelatedToAgent) |
	(are you and $ENT_RI_JBO_IsRelatedToAgent related|$V_RELATIVE) |
	(is $ENT_RI_JBO_IsRelatedToAgent your $V_RELATIVE)
)
{_mimId='RI_JBO_IsRelatedTo'}{_mimId += ENT_RI_JBO_IsRelatedToAgent._entity}
;

RULE_RI_JBO_IsFriendsWithAgent = (
	(are you ?(even|also) ?$V_ACTUALLY ?best friends with $ENT_RI_JBO_IsFriendsWithAgent) |
	(are you and ?(even|also) ?$V_ACTUALLY $ENT_RI_JBO_IsFriendsWithAgent ?best friends ?(with each other)) |
	(is|am $ENT_RI_JBO_IsFriendsWithAgent ?(even|also) ?$V_ACTUALLY your ?$V_ACTUAL ?best friend)
){_mimId='RI_JBO_IsFriendsWith'}{_mimId += ENT_RI_JBO_IsFriendsWithAgent._entity}
;

RULE_RI_JBO_IsFriendsWithUser = (
	(are we ?(even|also) ?$V_ACTUALLY friends ?(with each other)) |
	(are you (my|our friend)|([friend?s] with me|us))
){_mimId='RI_JBO_IsFriendsWithUser'}
;

RULE_RI_JBO_IsFriendsWithLM = (
	(are you ?(even|also) ?$V_ACTUALLY ?best friends with $LOOPMEMBER) |
	(are you and ?(even|also) ?$V_ACTUALLY $LOOPMEMBER ?best friends ?(with each other)) |
	(is $LOOPMEMBER ?(even|also) ?$V_ACTUALLY your ?$V_ACTUAL ?best friend)
){_mimId='RI_JBO_IsFriendsWithLM'}
{_loopmember=LOOPMEMBER._loopmember}
;

RULE_RI_JBO_Likes2017 = (
	(did you like|enjoy (this year)|(?(the year) 2017))|
	(did you have a good|$V_AWESOME (year|2017))|
	(how was your (year|2017))|
	(was your (year|2017) good|$V_AWESOME)|
	(how was ((this year)|(?(the year)2017)) ?(for you)) |
	(what|how was your (year|2017) ?like ?(for you))
){_mimId='RI_JBO_Likes2017'}
;
RULE_RI_JBO_LikesChristmasGift = (
	(do|did you like|love|enjoy (the|your) ?new (telescope|(christmas ([gift?s]|[present?s]))))
){_mimId='RI_JBO_LikesChristmasGift'}
;
RULE_RI_JBO_LikesHanukkahGift = (
	(do|did you like|love|enjoy (the|your) ?new ((fidget spinner)|((hanukkah|chanukah) ([gift?s]|[present?s]))))
){_mimId='RI_JBO_LikesHanukkahGift'}
;

RULE_RI_JBO_LikesAgent = (
    (do you ?$V_ACTUALLY like|love $ENT_RI_JBO_LikesAgent) |
    (do you ?$V_ACTUALLY believe|think|feel $ENT_RI_JBO_LikesAgent is $V_GOOD)
){_mimId='RI_JBO_Likes'}{_mimId += ENT_RI_JBO_LikesAgent._entity}
;

RULE_RI_JBO_LikesLM = (
	(do you ?$V_ACTUALLY like $LOOPMEMBER) |
	(do you ?$V_ACTUALLY believe|think|feel $LOOPMEMBER is $V_GOOD)
){_mimId='RI_JBO_LikesLM'}
{_loopmember=LOOPMEMBER._loopmember}
;

RULE_RI_JBO_DislikesAgent = (
    (do you ?$V_ACTUALLY hate|dislike|despise|detest|(not like)|(have ?a problem|rivalry with) $ENT_RI_JBO_DislikesAgent) |
    (are you and $ENT_RI_JBO_DislikesAgent ?$V_ACTUALLY rivals|(?mortal enemies)) |
    (is $ENT_RI_JBO_DislikesAgent ?$V_ACTUALLY your rival|enemy|(?arch nemisis)) |
	(are you ?ever ?$V_ACTUALLY jealous ?of $ENT_RI_JBO_DislikesAgent) |
    (do you (want|wish ?to)|(wish ?that you could) ?$V_ACTUALLY fight|kill|murder|destroy|smash $ENT_RI_JBO_DislikesAgent)
){_mimId='RI_JBO_Dislikes'}{_mimId += ENT_RI_JBO_DislikesAgent._entity}
;
