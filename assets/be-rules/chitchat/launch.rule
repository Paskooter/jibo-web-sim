	(mlk|(martin luther [king?(s|(\'s))]) ?(day|weekend)){_entity='MartinLutherKingDay'} |
	(orthodox easter) {_entity='OrthodoxEaster'} |
	(palm sunday) {_entity='PalmSunday'} |
	(passover) {_entity='Passover'} |
	([president?(?(\')s)] [day?s]){_entity='PresidentsDay'} |
	(purim|perm|perham){_entity='Purim'} |
	(tax day) {_entity='TaxDay'} |
	(thanksgiving|(thanks giving)){_entity='Thanksgiving'} |
	(?(saint|[st?.]) [patrick?(?(\')s)] ?day){_entity='StPatricksDay'} |
	(?(saint|[st?.]) [valentine?(s|(\'s))] ?day){_entity='ValentinesDay'} |
	(?(world|[?(inter)national]) sleep day) {_entity='WorldSleepDay'}
);

ENT_GIFT_HOLIDAYS =
(
	(christmas ?(eve|day)){_entity='Christmas'} |
	(hanukkah|chanukah){_entity='Hanukkah'} |
	(kwanzaa){_entity='Kwanzaa'} |
	(?(saint|st.) [valentine?(s|(\'s))] ?day){_entity='ValentinesDay'}
);

ENT_ACTIVITY =
(
	(school){_entity='School'}|
	(work){_entity='Work'}
);

ENT_MOVIES_TV_SHOWS = (
	(ready player one) {_entity='MovieReadyPlayerOne'} |
	(pacific rim uprising) {_entity='MoviePacificRimUprising'}
);

ENT_SHUFFLE_1 =
(
	((?$V_INTERESTING (black|(african amreican) history ?month [fact?s]|trivia))|(?(([some?(thing)] ?$V_INTERESTING)|(?$V_INTERESTING [fact?s]|trivia)) $w03 black|(african american) history ?month)) {_entity='BlackHistoryMonthFact'} |
    ((deep [thought?s])|(something ?$V_INTERESTING you\'ve|(you ?have) thought|(?been thinking) about)) {_entity='DeepThought'} |
    ((?$V_INTERESTING [fact?s])|(something $V_INTERESTING)) {_entity='FunFact'} |
	(((?$V_INTERESTING [fact?s] $w03)|(something ?$V_INTERESTING $w03) ?about ?las vegas)|(?$V_INTERESTING ?las vegas [fact?s])) {_entity='FunVegasFact'} |
    (?$V_INTERESTING health ?related [fact?s]|[tip?s]|advice) {_entity='HealthTip'} |
    ((?$V_INTERESTING [fact?s] about|[concern(s|(ing))]|(related ?to) people|([human?(s|(kind))] ?[being?s]))|([human?s] [fact?s])) {_entity='HumanFact'} |
    (?$V_INTERESTING technical [fact?s] ?(that\'s|(that ?is)) about|[concern(s|(ing))]|(related ?to) [you?(rself)]|$V_JIBO) {_entity='JiboFact'} |
    (?$V_INTERESTING (robot ?related [fact?s])|([fact?s] ?(that\'s|(that ?is)) about|[concern(s|(ing))] [robot?s])) {_entity='RobotFact'} |
    (?(my|our) [fortune?s]) {_entity='Fortune'} |
    ([haiku?s]) {_entity='Haiku'} |
    (?(one of) ?your [dream?s]) {_entity='Dream'} |
    (((sci fi)|(science fiction) [quote?s])|([quote?s] about|from|[concern(s|(ing))] (sci fi)|(science fiction))) {_entity='ScifiQuote'} |
    (weird|funny [word?s]) {_entity='WeirdWord'} |
    ((words ?of wisdom)|(wise words)|(weird|random|dubious advice)) {_entity='WordsOfWisdom'}
);

ENT_SHUFFLE_2 = 	#Shuffle 2 contains entities with GQA definitions that shouldn't match What is a ENTITY
(
	([haiku?s]) {_entity='Haiku'} |
	([palindrome?s]) {_entity='Palindrome'} |
    ([poem?s]) {_entity='Poem'}
);

ENT_KNOWN_SONGS =
(
	([dreidel?s] ?[song?s]){_entity='Dreidel'} |
	(jingle [bell?s]) {_entity='JingleBells'} |
	(winter wonderland) {_entity='WinterWonderland'} |
	(santa ?claus ?is coming to town) {_entity='SantaClausIsComingToTown'}|
	(feliz navidad) {_entity='FelizNavidad'} |
	(frosty ?the (show man|men)|snowman|snowmen) {_entity='FrostySnowman'} |
	(rudolph ?(the red nose|nosed reindeer)) {_entity='Rudolph'}
);

ENT_COMPETITION = (
	($ENT_KNOWN_SPORT_EVENT) {_entity=ENT_KNOWN_SPORT_EVENT._entity} |
	($ENT_KNOWN_SHOW_EVENT) {_entity=ENT_KNOWN_SHOW_EVENT._entity}
);

ENT_KNOWN_SPORT_EVENT = (
	(?the allstar|all-star|(all star) [game?s]){_entity='AllStarGameAmbiguous'} |
	(?the nba|baskteball allstar|all-star|(all star) [game?s]){_entity='AllStarGameNBA'} |
	(?the nhl|hockey allstar|all-star|(all star) [game?s]){_entity='AllStarGameNHL'} |
	(?the $w03 australian ?tennis open ?tennis) {_entity='AustralianOpenTennis'} |
	(?the (boston ?massachusetts marathon)|(marathon ?(of|in) boston)) {_entity='BostonMarathon '} |
	(?the $w03 (college ?football)|rose|sugar|orange|cotton|fiesta|peach|alamo bowl ?[game?s]) {_entity='CollegeBowl'} |
	(?the daytona ?(500|(five hundred))) {_entity='Daytona500'} |
	(?the $w03 (?national ?college football ?playoff ?national $w03 [championship?s] ?[game?s])|(national championship ?college football game)) {_entity='CollegeFootballChampionship'} |
	(?the (?[golf?(ing)] [master?(\')s])|([master?(\')s] [golf?(ing)]) ?tournament) {_entity='GolfMastersTournament'} |
	(?the nascar ?season) {_entity='NASCAR'} |
	(?the national [championship?s]) {_entity='NationalChampionshipAmbiguous'} |
	(?the (nba ?basketball)|basketball [playoff?s]) {_entity='NBAPlayoffs'} |
	(?the ?[men?(?(\')s)] ?([round?s] ?of) (march madness)|(final four)|(elite eight) ?[round?s]) {_entity='NCAABasketballTournamentMen'} |
	(?the ?[men?(?(\')s)] ([round?s] ?of sweet sixteen)|(sweet sixteen [round?s])) {_entity='NCAABasketballTournamentMen'} |
	(?the ?[men?(?(\')s)] ncaa|(n c a a) (?basketball ?[men?(?(\')s)])|(?[men?(?(\')s)] basketball) tournament|(national championship ?[game?s])) {_entity='NCAABasketballTournamentMen'} |
	(?the ?[men?(?(\')s)] (college basketball (national championship ?[game?s])|(?[men?(?(\')s)] tournament))) {_entity='NCAABasketballTournamentMen'} |
	(?the [women?(?(\')s)] ?([round?s] ?of) (march madness)|(final four)|(elite eight) ?[round?s]) {_entity='NCAABasketballTournamentWomen'} |
	(?the [women?(?(\')s)] ([round?s] ?of sweet sixteen)|(sweet sixteen [round?s])) {_entity='NCAABasketballTournamentWomen'} |
	(?the ?(ncaa|(n c a a)) [women?(?(\')s)] ?(ncaa|(n c a a)) national championship ?[game?s]) {_entity='NCAABasketballTournamentWomen'} |
	(?the [women?(?(\')s)] (ncaa|(n c a a) ?basketball)|(college basketball) tournament) {_entity='NCAABasketballTournamentWomen'} |
	(?the $w03 nfl|(national football league)|afc|(american football conference)|nfc|(national football conference)|(afc nfc)|(nfc afc) ?championship ?football ?((play [off?s])|[playoff?s])) {_entity='NFLPlayoffs'} |
	(?the (nhl ?hockey)|hockey|(stanley cup) playoffs) {_entity='NHLPlayoffs'} |
	(?the $w03 superbowl|(super bowl)) {_entity='SuperBowl'} |
	((?the $w03 ?winter [olympic?s] ?[game?s])|(?the $w03 winter ?[olympic?s] [game?s])|(?the ?winter [game?s] of ?the $w03 [olympic?s])) {_entity='WinterOlympics'} |
	(?the $w03 winter x [game?s]) {_entity='WinterXGames'} |
	(?the $w03 world series) {_entity='WorldSeries'}
);

ENT_KNOWN_SHOW_EVENT = (
	(?(the|an) ([oscar?(?(\')s)] ?night)|(academy [award?s])) {_entity='AcademyAwards'} |
	(?the ?(academy ?of) country music [award?s]) {_entity='AcademyCountryMusicAwards'} |
	(?the [bachelor?s] ?[show?s]) {_entity='BachelorShow'} |
	(?the [bachelorette?s] ?[show?s]) {_entity='BacheloretteShow'} |
	(?the $w03 golden [globe?s] ?[award?s]) {_entity='GoldenGlobes'} |
	(?the $w03 [grammy?s] ?[award?s]) {_entity='Grammys'} |
	(?the iheartradio|([i?(-)heart]|(i heart) ?radio) music [award?s]) {_entity='iHeartRadioMusicAwards'}
);
ENT_UNKNOWN_SONGS =
(
	(have yourself a merry little christmas) |
	(silent night) |
	(joy to the world) |
	(silver bells|bell) |
	(let it snow) |
	(santa baby) |
	(white christmas) |
	(oh holy night) |
	(rockin around the christmas tree) |
	(we wish you a merry christmas) |
	(?a holly jolly christmas)
){_entity='Unknown'};



KU_PREFIXES= (
    (i (was ?$V_ACTUALLY saying|(trying to say))|(meant to say) $*) |
    ($V_CANYOU ?$V_ACTUALLY access $*) |
    ($V_CANYOU ?$V_ACTUALLY get ?(me|us) [info?(rmation)] $*) |
    ($V_CANYOU ?$V_ACTUALLY give ?(me|us) [info?(rmation)] $*) |
    (do you ?$V_ACTUALLY have [info?(rmation)] $*) |
    ((i ?$V_ACTUALLY want)|(i\'d|(i would) ?$V_ACTUALLY like) ?to know|(hear about) $*) |
    (i ?$V_ACTUALLY wish ?to know|(hear about) $*) |
    (i ?$V_ACTUALLY wish you $* tell $*)
~0.1);

