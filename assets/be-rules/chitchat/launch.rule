RULE_SRS_Depression = (
    (i\'m|(i have|am|feel|(?am feeling)) ?$V_VERY_SERIOUS $V_DEPRESSED) |
    (i\'m|(i am|feel|(?am feeling)) $V_VERY_SERIOUS $V_SAD_LIMITED) |
    (i\'m|(i am) ?in the depths of depression) |
    (i\'m|(i ?(am|feel)) (stuck ?in ?a)|($V_CANNOT|never (stop feeling)|(snap out ?of) this) ?$V_VERY_SERIOUS (dark place)|funk|(deep depression)) |
    (i $V_CANNOT|never (stop feeling)|(snap out ?of) ?this ?$V_VERY_SERIOUS $V_SAD_LIMITED|$V_DEPRESSED) |
    ((i never|don\'t|$V_CANNOT feel)|(nothing ?ever is|feels) happy|good|fun|enjoyable ?anymore ?(to me))
){_intent='SRS_Depression'};

RULE_SRS_MentalHealthOther = (
