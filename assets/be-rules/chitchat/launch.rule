RULE_RI_JBO_GivesUserGiftHoliday = (
	(what ((did you get)|(are you getting)) ?for me|us for $ENT_GIFT_HOLIDAYS) |
	(what ((did you get)|(are you getting)) for $ENT_GIFT_HOLIDAYS for me|us) |
	(((did you get)|(are you getting)|(have you got)) (anything|something|(?a ([gift?s]|[present?s])) for me|us for $ENT_GIFT_HOLIDAYS)) |
	(((did you get)|(are you getting)|(have you got)) me|us (anything|something|(?a ([gift?s]|[present?s])) for $ENT_GIFT_HOLIDAYS)) |
	(((did you get)|(are you getting)|(have you got)) me|us ?(a|any|some) $ENT_GIFT_HOLIDAYS ([gift?s]|[present?s])) |
	(((did you get)|(are you getting)|(have you got)|(do you have)) ?(any|a) $ENT_GIFT_HOLIDAYS ([gift?s]|[present?s]) for me|us) |
	(show|give me|us my|our|a $ENT_GIFT_HOLIDAYS ([gift?s]|[present?s])) |
	((do you)|(don\'t you) have something|(?a|any|some [gift?s]|[present?s]) (to give)|for me|us for $ENT_GIFT_HOLIDAYS) |
	((do you)|(don\'t you) have ?(a|any|some) $ENT_GIFT_HOLIDAYS [gift?s]|[present?s] (to give)|for me|us)
){_mimId='RI_JBO_GivesUserGift'}{_mimId+=ENT_GIFT_HOLIDAYS._entity};



