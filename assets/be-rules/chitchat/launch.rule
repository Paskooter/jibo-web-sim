###Entities###

#Actions
ENT_RI_JBO_CanAction = (
	([answer?(ing)] me|my|us|our){_entity='AnswerUser'} |
	(?(need ?to) [breath?(e|(ing))] ?(air|oxygen)) {_entity='Breathe'} |
	(([be?(ing)] sarcastic)|([us(e|(ing))] sarcasm)|([talk?(ing)]|[speak?(ing)] sarcastically|(using sarcasm))){_entity='BeSarcastic'} |
 	([clean?(ing)] ?up ?the floor) {_entity='CleanFloor'} |
 	([clean?(ing)] ?up ?the table) {_entity='CleanTable'} |
	([cook?(ing)]|[bak(e|(ing))]|([prepar(e|(ing))]|[mak(e|(ing))] [food?s]|[recipe?s])){_entity='Cook'} |
	([cry?(ing)]){_entity='Cry'} |
 	([curs?(e|(ing))]|[swear?(ing)]) {_entity='Curse'} |
	([danc(e|(ing))]) {_entity='Dance'} |
 	(?([do?(ing)]) ?(the|$V_POSESSIVES) laundry) {_entity='DoLaundry'} |
	(
		((do|wash|clean|dust|vacuum|sweep|mop|wipe) $w03 ([dish?(es)]|[refrigerator?s]|[stove?s]|[oven?s]|[car?s]|[truck?s]|$SS_ROOM_IN_HOUSE)) |
		(set $w03 [table?s]) |
		(empty $w03 dishwasher|trash) |
		(clear $w03 table) |
		(take out $w03 trash) | (take $w03 trash out) |
		(feed ?(the|my|our) $w03 $SS_PET|$SS_FAMILY_MEMBER|$LOOPMEMBER|[pet?s]|[famil(y|(ies))]) |
		(feed me|us) |
		(water $w03 [plant?s]|[flower?s]|lawn|yard) |
		(mow $w03 lawn|grass|yard)
	) {_entity='DoHouseholdChore'} |
	([dream?(ing)]|([hav(e|(ing))] ?any [dream?s] ?(last night))){_entity='Dream'} |
	([eat?(ing)] (thanksgiving food|dinner)|(?food $w03 thanksgiving)){_entity='EatThanksgivingFood'} |
	(([help?(ing)] me ?to understand)|[explain?(ing)] women|men|girls|boys|(people ?(of|with) (?the opposite)|(?a different) gender)){_entity='ExplainMenWomen'} |
	([exercis(e|(ing))]|([work?(ing)] out)) {_entity='Exercise'} |
	([feel?(ing)]|felt (anything)|(at all)|(?any [emotion?s]|[mood?s]) ?(ever|(at all))){_entity='FeelAnything'} |
	([fly?(ing)]){_entity='Fly'} |
	((gotten|[get?(ting)])|(felt|[feel?(ing)]) ?(too|really) cold|cool){_entity='GetCold'} |
	((gotten|[get?(ting)])|(felt|[feel?(ing)]) ?(really) depressed){_entity='GetDepressed'} |
