	(((who is)|(who\'s)|(tell me|us about)|(what ?do you know about)|(have you met)|(did you meet) $LOOPMEMBER ?yet)|(do you know who $LOOPMEMBER is)|(do you know $LOOPMEMBER)|(have you and $LOOPMEMBER met ?(each other) ?yet)|(?do you and $LOOPMEMBER know each other)){_intent='USR_WhoIsLoopMember'}{_loopmember=LOOPMEMBER._loopmember}
;
RULE_USR_WhoShouldIVoteFor = (who|(what|which candidate) should i vote for){_intent='USR_WhoShouldIVoteFor'}
;
RULE_USR_WillYouMarryMe =
	((?((will you)|(?do you want ?to)) (marry me)|(get married to|with me))|(((can|should we)|(are we able|allowed ?to)|(is it possible for us ?to)) marry|(get married) ?(?to each other))|(i want ?for (us ?to get married)|(you ?to marry|(get married to|with) me)|(?to marry|(get married to|with) you))|(?(?do you think) we should (marry ?(each other))|(get married ?(?to each other)))){_intent='USR_WillYouMarryMe'}
;

### Serious Rules ###

RULE_SRS_DrugAddiction =
(
    ((i|we ?(am|are))|i\'ve|we\'ve|i\'m|we\'re ?always ?$V_ACTUALLY $V_CRAVE ?$V_USE_DRUG ?(a|an|the|that|some) [drug?s]|$V_VARIOUS_DRUGS|[painkiller?s]) |
    (i\'m|we\'re|(i|we ?(am|are|(might be))) $* addicted|(have ?an $* addiction) ?to [drug?s]|$V_VARIOUS_DRUGS|[painkiller?s]) |
    (i\'m|we\'re|(i|we ?(am|are|(might be))) $* [drug?s]|$V_VARIOUS_DRUGS|[painkiller?s] addict) |
    (i|we have ?a $* [drug?s]|$V_VARIOUS_DRUGS|[painkiller?s] problem|addiction) |
    (i|we $V_CANNOT stop $V_USE_DRUG|[abus(e|(ed)|(es)|(ing))] [drug?s]|$V_VARIOUS_DRUGS|[painkiller?s]) |
    (can you ?find $* help $* ?(with|for) my|our $* [drug?s]|$V_VARIOUS_DRUGS|[painkiller?s] problem|addiction)
){_intent='SRS_DrugAddiction'};

RULE_SRS_Alcoholism =
